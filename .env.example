# NASA — Environment Variables Template
#
# Copia esse arquivo pra .env.local (dev) ou seta no host de produção
# (Vercel / VPS / Fly / etc). Os valores reais NÃO devem ser commitados.
#
# Convenção: NEXT_PUBLIC_* são expostos no browser (não ponha segredo).
# Demais vars são server-side only.

# ─────────────────────────────────────────────────────────────────────
# DATABASE — PostgreSQL 17 + pgvector
# ─────────────────────────────────────────────────────────────────────
# Dev local (docker-compose): postgresql://docker:docker@localhost:5432/nasa_db
# Prod: connection string do seu provedor (Neon, Supabase, RDS, etc).
DATABASE_URL=postgresql://docker:docker@localhost:5432/nasa_db

# ─────────────────────────────────────────────────────────────────────
# AUTH — better-auth
# ─────────────────────────────────────────────────────────────────────
BETTER_AUTH_SECRET=                       # gerar com `openssl rand -hex 32`
BETTER_AUTH_URL=http://localhost:3000     # URL canônica do app (mudar em prod)
BETTER_AUTH_EMAIL=                        # email de sistema (notifs)
GOOGLE_CLIENT_ID=                         # OAuth Google
GOOGLE_CLIENT_SECRET=

# ─────────────────────────────────────────────────────────────────────
# APP URLs (públicos)
# ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ─────────────────────────────────────────────────────────────────────
# AI / LLM
# ─────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=                           # sk-... pro orchestrator do Astro
LLM_KEY=                                  # genérico (alguns features legacy)
GOOGLE_GENERATIVE_AI_API_KEY=             # Gemini (planner futuro)
# ASTRO_DEFAULT_MODEL=gpt-4o-mini         # opcional override

# ─────────────────────────────────────────────────────────────────────
# PIPER TTS — Voz oficial do Astro (Faber pt-BR VITS)
# ─────────────────────────────────────────────────────────────────────
# Habilita o cliente a usar Piper em vez do Web Speech do browser.
# Sem isso (ou se Piper offline), cai pro fallback degradado.
NEXT_PUBLIC_PIPER_ENABLED=true

# URL do container Piper. Em dev com docker-compose: http://localhost:10200.
# Em prod: URL pública/interna do host que está rodando o container Piper
# (ex: https://piper.nasa.example.com OU IP interno se same-VPC).
PIPER_HTTP_URL=http://localhost:10200

# ─────────────────────────────────────────────────────────────────────
# REALTIME — Pusher (notificações + alertas)
# ─────────────────────────────────────────────────────────────────────
PUSHER_APP_ID=
PUSHER_SECRET=
NEXT_PUBLIC_PUSHER_APP_KEY=
NEXT_PUBLIC_PUSHER_CLUSTER=us2

# ─────────────────────────────────────────────────────────────────────
# WHATSAPP — UazAPI (Astro send_whatsapp_message, alert engine)
# ─────────────────────────────────────────────────────────────────────
UAZAPI_TOKEN=
NEXT_PUBLIC_UAZAPI_BASE_URL=

# ─────────────────────────────────────────────────────────────────────
# STORAGE — S3 / R2
# ─────────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_ENDPOINT_URL_IAM=
NEXT_PUBLIC_S3_BUCKET_CONSTRUCTOR_URL=    # CDN URL pro assets do uploader

# ─────────────────────────────────────────────────────────────────────
# PAYMENTS — Stripe
# ─────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ─────────────────────────────────────────────────────────────────────
# EMAIL — Resend
# ─────────────────────────────────────────────────────────────────────
RESEND_API_KEY=

# ─────────────────────────────────────────────────────────────────────
# INTEGRATIONS — Meta Ads
# ─────────────────────────────────────────────────────────────────────
META_APP_ID=
META_APP_SECRET=
META_OAUTH_REDIRECT_URI=
