{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Next.js Dev Server",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["dev"],
      "port": 3000,
      "autoPort": true
    },
    {
      "name": "Next.js Dev Server (HTTPS)",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["dev", "--experimental-https"],
      "port": 3000,
      "autoPort": true
    }
  ]
}
