  thumbnail      String?

  orgProjectId   String?  @map("org_project_id")
  clientOrgName  String?  @map("client_org_name")
  campaignId     String?  @map("campaign_id")
  referenceLinks String[] @default([]) @map("reference_links")

  // ── NASA Planner 2.0: vínculo com Workspace Action + templates ──
  // `actionId`: quando o post foi criado via "Criar com Planner" no popup
  // do view-action-modal do Workspace, guarda a Action de origem pra
  // rastreabilidade e sync de metadados (description → caption, etc.)
  // `templateId`: template estático aplicado (sprint 2)
  // `videoTranscriptionData`: words[], chapters[], highlights[] do
  // AssemblyAI (sprint 2) — usado pra legendas word-by-word + cortes
  // inteligentes baseados em viral moments.
  // `videoEditTimelineJson`: timeline completa do editor CapCut-style
  // (clips + transitions + overlays + cta) — usado como input pro
  // Remotion Lambda no render final (sprint 3).
  actionId               String? @map("action_id")
  templateId             String? @map("template_id")
  videoTranscriptionData Json?   @map("video_transcription_data")
  videoEditTimelineJson  Json?   @map("video_edit_timeline_json")

  logoKey       String? @map("logo_key")
  videoKey      String? @map("video_key")
  videoDuration Int?    @map("video_duration")
  isAd          Boolean @default(false) @map("is_ad")

  targetIgAccountId String? @map("target_ig_account_id")
  targetFbPageId    String? @map("target_fb_page_id")

  externalIgPostId String? @map("external_ig_post_id")
  externalFbPostId String? @map("external_fb_post_id")
  publishError     String? @map("publish_error")

  metricsImpressions Int?      @map("metrics_impressions")
  metricsReach       Int?      @map("metrics_reach")
  metricsLikes       Int?      @map("metrics_likes")
  metricsComments    Int?      @map("metrics_comments")
  metricsShares      Int?      @map("metrics_shares")
  metricsVideoViews  Int?      @map("metrics_video_views")
  metricsSyncedAt    DateTime? @map("metrics_synced_at")
  metricsSyncError   String?   @map("metrics_sync_error")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  planner    NasaPlanner            @relation(fields: [plannerId], references: [id], onDelete: Cascade)
  createdBy  User                   @relation("NasaPlannerPostCreatedBy", fields: [createdById], references: [id])
  orgProject OrgProject?            @relation(fields: [orgProjectId], references: [id], onDelete: SetNull)
  campaign   NasaCampaignPlanner?   @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  action     Action?                @relation("ActionPlannerPosts", fields: [actionId], references: [id], onDelete: SetNull)
  template   NasaPlannerPostTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  slides     NasaPlannerPostSlide[]

  @@index([plannerId, status])
  @@index([plannerId, scheduledAt])
  @@index([organizationId])
  @@index([actionId])
  @@index([templateId])
  @@map("nasa_planner_posts")
}

// ── Templates de post estático brandeáveis (NASA Planner 2.0 / sprint 2) ──
// Cada template é um layout Konva serializado (`layoutJson`) com posições
// e tipos das camadas (image, headline, subhead, footer, cta, logo). O
// editor (`post-template-editor.tsx`) carrega o layout, aplica o brand
// kit da org automaticamente (fontes do `brandFontHeading/Body`, paleta
// do `brandPaletteHex`) e permite o usuário ajustar antes de renderizar
// via Remotion Lambda. Templates `isGlobal` são curados pela plataforma;
// templates por-org permitem personalizações salvas pelo usuário.
model NasaPlannerPostTemplate {
  id             String   @id @default(cuid())
  name           String
  slug           String   @unique
  category       String   // "minimal-serif", "bold-modern", "elegant-luxury", "vibrant-popart", "clean-corporate"
  ratio          String   // "1:1", "9:16", "4:5", "1.91:1"
  layoutJson     Json     // Konva nodes spec: positions + types of layers
  previewKey     String?  @map("preview_key") // S3 key do thumb estático pra galeria
  isGlobal       Boolean  @default(false) @map("is_global")
  organizationId String?  @map("organization_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  posts        NasaPlannerPost[]

  @@index([organizationId, isGlobal])
  @@index([category])
  @@map("nasa_planner_post_templates")
}

model NasaPlannerPostSlide {
  id     String @id @default(cuid())
  postId String @map("post_id")
  order  Int    @default(0)

  imageKey      String? @map("image_key")
  videoKey      String? @map("video_key")
  targetFormat  String? @default("1:1") @map("target_format")
