// ─── Admin Notifications ──────────────────────────────────────────────────────

model AdminNotification {
  id             String   @id @default(cuid())
  title          String
  body           String
  type           String   @default("info") // info | warning | success | error
  appKey         String?  @map("app_key")
  actionUrl      String?  @map("action_url")
  metadata       Json?
  targetType     String   @default("all") // all | org | user
  targetId       String?  @map("target_id") // orgId ou userId
  organizationId String?  @map("organization_id")
  createdBy      String   @map("created_by") // userID ou "SYSTEM"
  sentWhatsApp   Boolean  @default(false) @map("sent_whatsapp")
  createdAt      DateTime @default(now()) @map("created_at")

  // ─── Camada de Alertas ────────────────────────────────────────────
  // severity governa o tratamento visual (info=bell, warning=toast,
  // critical=popup). displaySurface permite override por regra.
  // requiresAck=true só fecha o popup quando user confirmar explicitamente.
  severity       String   @default("info") // info | warning | critical
  displaySurface String   @default("bell") @map("display_surface") // bell | toast | popup
  requiresAck    Boolean  @default(false) @map("requires_ack")
  alertRuleId    String?  @map("alert_rule_id")
  alertRule      AlertRule? @relation(fields: [alertRuleId], references: [id], onDelete: SetNull)
  eventType      String?  @map("event_type")
  eventPayload   Json?    @map("event_payload")

  reads AdminNotificationRead[]

  @@index([targetType])
  @@index([createdAt])
  @@index([organizationId])
  @@index([severity, requiresAck])
  @@index([alertRuleId])
  @@map("admin_notification")
}

model AdminNotificationRead {
  id             String            @id @default(cuid())
  notificationId String            @map("notification_id")
  notification   AdminNotification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  userId         String            @map("user_id")
  readAt         DateTime          @default(now()) @map("read_at")
  // Confirmação explícita do popup crítico (separado de readAt — bell pode
  // "ler" passivamente mas critical exige click no botão de confirmar).
  acknowledgedAt DateTime?         @map("acknowledged_at")

  @@unique([notificationId, userId])
  @@index([userId])
  @@map("admin_notification_read")
}

// ─────────────────────────────────────────────
// ALERTS — Regras configuráveis + dedupe
// ─────────────────────────────────────────────

/// Regra de alerta — criada via Astro Command (sem UI dedicada).
/// organizationId=null → regra global do Master.
model AlertRule {
  id              String   @id @default(cuid())
  organizationId  String?  @map("organization_id")
  name            String
  description     String?
  eventType       String   @map("event_type") // chave do AlertCatalog
  params          Json     @default("{}") // params específicos (ex: { statusId, days, threshold })
  severity        String   @default("info") // info | warning | critical
  audience        Json // { kind: "lead_responsible" | "org_supervisors" | "org_admins" | "user" | "whole_org", userIds?: string[] }
  channels        Json     @default("[\"in_app\"]") // ["in_app", "whatsapp"] — override de prefs
  displaySurface  String   @default("bell") @map("display_surface") // bell | toast | popup
  isActive        Boolean  @default(true) @map("is_active")
  createdBy       String   @map("created_by")
  cooldownMinutes Int?     @map("cooldown_minutes")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  organization  Organization?       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  notifications AdminNotification[]
  dispatches    AlertDispatch[]

  @@index([eventType, isActive])
  @@index([organizationId])
  @@map("alert_rule")
}

/// Ledger de idempotência — uma chave (alertRuleId, entityKey) só dispara 1x.
/// entityKey é construído pelo handler do evento (ex: "lead-stale:<id>:<YYYY-MM-DD>").
model AlertDispatch {
  id           String   @id @default(cuid())
  alertRuleId  String   @map("alert_rule_id")
  alertRule    AlertRule @relation(fields: [alertRuleId], references: [id], onDelete: Cascade)
  entityKey    String   @map("entity_key")
  dispatchedAt DateTime @default(now()) @map("dispatched_at")

  @@unique([alertRuleId, entityKey])
  @@index([alertRuleId, dispatchedAt])
  @@map("alert_dispatch")
}

// ─────────────────────────────────────────────
// SPACE POINT — Gamification System
// ─────────────────────────────────────────────

/// Predefined level thresholds (seeded once, global for all orgs)
model SpacePointLevel {
  id             String @id @default(cuid())
  order          Int    @unique
  name           String // "Terra", "Lua", "Marte", "Saturno"…
  requiredPoints Int    @map("required_points")
  badgeNumber    Int    @map("badge_number") // 1-24 → /public/space-point/badges/{n}.svg
  planetEmoji    String @default("🪐") @map("planet_emoji")

  seals UserSpacePointSeal[]

  @@map("space_point_level")
}

/// Per-org Star consumption rules (debits per action)
model StarRule {
  id              String   @id @default(cuid())
  orgId           String   @map("org_id")
  action          String
  label           String
  stars           Int      @default(0) // 0 = free
  cooldownHours   Int?     @map("cooldown_hours")
  isActive        Boolean  @default(true) @map("is_active")
  popupTemplateId String?  @map("popup_template_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, action])
  @@index([orgId])
  @@map("star_rule")
}

/// Global configurable rules: which actions earn how many points (fixed for all users)
model SpacePointRule {
  id              String   @id @default(cuid())
  action          String   @unique // "lead_won" | "create_event" | ...
  label           String // human-readable, shown in settings
  points          Int      @default(0)
  cooldownHours   Int?     @map("cooldown_hours") // null = unlimited
  isActive        Boolean  @default(true) @map("is_active")
  popupTemplateId String?  @map("popup_template_id") // optional linked popup template
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  transactions SpacePointTransaction[]

  @@map("space_point_rule")
}

/// Prizes/awards per ranking position per org
model SpacePointRankingPrize {
  id          String   @id @default(cuid())
  orgId       String   @map("org_id")
  rank        Int // 1 = 1st place, 2 = 2nd, etc.
  period      String   @default("monthly") // "weekly" | "biweekly" | "monthly" | "annual" | "alltime"
  title       String
  description String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, rank, period])
  @@index([orgId])
  @@map("space_point_ranking_prize")
}

/// Global accumulated points + level tracking per user (platform-wide)
model UserSpacePoint {
  id           String    @id @default(cuid())
  userId       String    @unique @map("user_id")
  orgId        String    @map("org_id")
  totalPoints  Int       @default(0) @map("total_points")
  weeklyPoints Int       @default(0) @map("weekly_points")
  weekStart    DateTime? @map("week_start")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  user         User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  org          Organization            @relation(fields: [orgId], references: [id], onDelete: Cascade)
  transactions SpacePointTransaction[]
  seals        UserSpacePointSeal[]

  @@map("user_space_point")
}

/// Audit log of every point event
model SpacePointTransaction {
  id          String   @id @default(cuid())
  userPointId String   @map("user_point_id")
  ruleId      String?  @map("rule_id")
  orgId       String?  @map("org_id") // Track which org triggered the earn
  points      Int
  description String
  metadata    Json?    @default("{}")
  createdAt   DateTime @default(now()) @map("created_at")

  userPoint UserSpacePoint  @relation(fields: [userPointId], references: [id], onDelete: Cascade)
  rule      SpacePointRule? @relation(fields: [ruleId], references: [id], onDelete: SetNull)
  org       Organization?   @relation(fields: [orgId], references: [id], onDelete: SetNull)

  @@index([userPointId])
  @@index([userPointId, createdAt])
  @@index([orgId])
  @@index([orgId, createdAt])
  @@map("space_point_transaction")
}

/// Which level seals the user has unlocked
model UserSpacePointSeal {
  id          String   @id @default(cuid())
  userPointId String   @map("user_point_id")
  levelId     String   @map("level_id")
  earnedAt    DateTime @default(now()) @map("earned_at")

  userPoint UserSpacePoint  @relation(fields: [userPointId], references: [id], onDelete: Cascade)
  level     SpacePointLevel @relation(fields: [levelId], references: [id], onDelete: Cascade)

  @@unique([userPointId, levelId])
  @@index([userPointId])
  @@map("user_space_point_seal")
}

/// Key→URL store for all configurable platform assets (badges, app icons, integration icons, branding)
model PlatformAsset {
  id        String   @id @default(cuid())
  key       String   @unique // "badge:1", "app:tracking", "integration:whatsapp-business", "platform:logo"
  url       String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("platform_asset")
}

/// Platform-level payment gateway configurations (Stripe, Asaas, etc.)
model PaymentGatewayConfig {
  id            String   @id @default(cuid())
  provider      String // "stripe" | "asaas"
  label         String?
  secretKey     String
  publicKey     String? // Stripe publishable key
  webhookSecret String? // Stripe webhook signing secret
  environment   String   @default("production") // "sandbox" | "production"
  isActive      Boolean  @default(true) @map("is_active")
  isDefault     Boolean  @default(false) @map("is_default")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  payments StarsPayment[]

  @@map("payment_gateway_config")
}

/// Tracks individual Stars purchase payment attempts
model StarsPayment {
  id             String   @id @default(cuid())
  userId         String   @map("user_id")
  organizationId String   @map("organization_id")
  packageId      String   @map("package_id")
  starsAmount    Int      @map("stars_amount")
  amountBrl      Decimal  @map("amount_brl")
  provider       String
  externalId     String?  @map("external_id")
  status         String   @default("pending") // pending | paid | failed | expired
  metadata       Json     @default("{}")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  gatewayConfig PaymentGatewayConfig? @relation(fields: [gatewayId], references: [id])
  gatewayId     String?               @map("gateway_id")

  // ── NASA Partner ──
  partnerCommission   PartnerCommission?
  partnerStarPurchase PartnerStarPurchase?

  @@index([userId])
  @@index([organizationId])
  @@index([externalId])
  @@index([status])
  @@map("stars_payment")
}

// ─────────────────────────────────────────────
// NASA PAYMENT
// ─────────────────────────────────────────────

enum FinancialEntryStatus {
  PENDING // Pendente
  PARTIAL // Pago Parcial
  PAID // Pago
  OVERDUE // Vencido
  CANCELLED // Cancelado
}

enum FinancialEntryType {
  RECEIVABLE // Conta a Receber
  PAYABLE // Conta a Pagar
}

enum PaymentAccountType {
  CHECKING // Conta Corrente
  SAVINGS // Poupança
  CASH // Caixa físico
  DIGITAL // Carteira digital
}

enum FinancialCategoryType {
  REVENUE // Receita
  EXPENSE // Despesa
  COST // Custo
}

model PaymentBankAccount {
  id             String             @id @default(cuid())
  organizationId String             @map("organization_id")
  name           String
  bankName       String?            @map("bank_name")
  bankCode       String?            @map("bank_code")
  agency         String?
  account        String?
  type           PaymentAccountType @default(CHECKING)
  balance        Int                @default(0) // em centavos
  isActive       Boolean            @default(true) @map("is_active")
  isDefault      Boolean            @default(false) @map("is_default")
  color          String?            @default("#1E90FF")
  createdAt      DateTime           @default(now()) @map("created_at")
  updatedAt      DateTime           @updatedAt @map("updated_at")

  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  entries      PaymentEntry[]

  @@index([organizationId])
  @@map("payment_bank_accounts")
}

model PaymentCategory {
  id             String                @id @default(cuid())
  organizationId String                @map("organization_id")
  name           String
  type           FinancialCategoryType
  color          String?               @default("#1E90FF")
  icon           String?
  parentId       String?               @map("parent_id")
  isActive       Boolean               @default(true) @map("is_active")
  createdAt      DateTime              @default(now()) @map("created_at")
  updatedAt      DateTime              @updatedAt @map("updated_at")

  organization Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  parent       PaymentCategory?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children     PaymentCategory[] @relation("CategoryHierarchy")
  entries      PaymentEntry[]

  @@index([organizationId])
  @@map("payment_categories")
}

model PaymentCostCenter {
  id             String   @id @default(cuid())
  organizationId String   @map("organization_id")
  name           String
  description    String?
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  entries      PaymentEntry[]

  @@index([organizationId])
  @@map("payment_cost_centers")
}

model PaymentContact {
  id             String   @id @default(cuid())
  organizationId String   @map("organization_id")
  name           String
  document       String? // CPF ou CNPJ
  email          String?
  phone          String?
  contactType    String   @default("BOTH") @map("contact_type") // CUSTOMER, SUPPLIER, BOTH
  notes          String?
  isActive       Boolean  @default(true) @map("is_active")
  creditLimit    Int      @default(0) @map("credit_limit") // em centavos
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  entries      PaymentEntry[]

  @@index([organizationId])
  @@map("payment_contacts")
}

model PaymentAccess {
  id             String   @id @default(cuid())
  userId         String   @map("user_id")
  organizationId String   @map("organization_id")
  passwordHash   String   @map("password_hash")
  isAuthorized   Boolean  @default(false) @map("is_authorized")
  phone          String? // para envio de PIN via WhatsApp
  authorizedById String?  @map("authorized_by_id")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  user         User         @relation("PaymentAccessUser", fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  authorizedBy User?        @relation("PaymentAccessAuthorizer", fields: [authorizedById], references: [id])

  @@unique([userId, organizationId])
  @@index([organizationId])
  @@map("payment_access")
}

model PaymentEntry {
  id             String               @id @default(cuid())
  organizationId String               @map("organization_id")
  type           FinancialEntryType
  status         FinancialEntryStatus @default(PENDING)

  description    String
  amount         Int // em centavos
  paidAmount     Int       @default(0) @map("paid_amount") // em centavos
  dueDate        DateTime  @map("due_date")
  paidAt         DateTime? @map("paid_at")
  competenceDate DateTime? @map("competence_date")

  documentNumber String? @map("document_number")
  notes          String?
  attachmentUrl  String? @map("attachment_url")

  categoryId   String? @map("category_id")
  costCenterId String? @map("cost_center_id")
  contactId    String? @map("contact_id")
  accountId    String? @map("account_id")
  trackingId   String? @map("tracking_id")
  // Vínculo direto ao Lead — usado pela feature de Orçamento no chat:
  // permite filtrar "A receber" por lead específico (em vez de só por tracking).
  leadId       String? @map("lead_id")

  // Parcelamento
  installmentTotal   Int?    @map("installment_total")
  installmentCurrent Int?    @map("installment_current")
  installmentGroupId String? @map("installment_group_id")

  // Recorrência
  isRecurring    Boolean @default(false) @map("is_recurring")
  recurrenceType String? @map("recurrence_type") // daily, weekly, monthly, yearly

  createdById String?  @map("created_by_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  organization Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  category     PaymentCategory?    @relation(fields: [categoryId], references: [id])
  costCenter   PaymentCostCenter?  @relation(fields: [costCenterId], references: [id])
  contact      PaymentContact?     @relation(fields: [contactId], references: [id])
  account      PaymentBankAccount? @relation(fields: [accountId], references: [id])
  tracking     Tracking?           @relation(fields: [trackingId], references: [id], onDelete: SetNull)
  lead         Lead?               @relation(fields: [leadId], references: [id], onDelete: SetNull)
  createdBy    User?               @relation("PaymentEntryCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([type])
  @@index([status])
  @@index([dueDate])
  @@index([contactId])
  @@index([categoryId])
  @@index([installmentGroupId])
  @@index([trackingId])
  @@index([leadId])
  @@map("payment_entries")
}

// ─── ORG PROJECTS / CLIENTES ────────────────────────────────────────────────

model OrgProject {
  id             String  @id @default(cuid())
  organizationId String  @map("organization_id")
  name           String
  avatar         String?
  type           String  @default("client") // "project" | "client" | "entity" | custom
  description    String?
  color          String? @default("#7c3aed")
  isActive       Boolean @default(true) @map("is_active")

  // Marca / Brand
  slogan         String?
  website        String?
  icp            String?
  positioning    String?
  voiceTone      String? @map("voice_tone")
  visual         Json    @default("{}")
  aiInstructions String? @map("ai_instructions")
  swot           Json    @default("{}")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  organization              Organization              @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  leads                     Lead[]
  trackings                 Tracking[]
  actions                   Action[]
  workspaces                Workspace[]
  appointments              Appointment[]
  forgeProposals            ForgeProposal[]
  nasaPlanners              NasaPlanner[]
  campaignPlanners          NasaCampaignPlanner[]
  nasaPlannerPosts          NasaPlannerPost[]
  clientOnboardingProcesses ClientOnboardingProcess[]

  isPublicOnSpace Boolean @default(false) @map("is_public_on_space")

  @@index([organizationId])
  @@map("org_projects")
}

// ─── NASA Campaign Planner ──────────────────────────────────────────────────

enum NasaCampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
  ARCHIVED
}

enum NasaCampaignEventType {
  TRAINING
  STRATEGIC_MEETING
  REVIEW
  KICKOFF
  PRESENTATION
  DEADLINE
}

enum NasaCampaignEventStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
  RESCHEDULED
}

enum NasaCampaignBrandAssetType {
  LOGO
  COLOR_PALETTE
  FONT
  LINK
  DOCUMENT
  IMAGE
  VIDEO
}

enum NasaCampaignTaskStatus {
  PENDING
  IN_PROGRESS
  REVIEW
  COMPLETED
  BLOCKED
}

enum NasaCampaignTaskPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model NasaCampaignPlanner {
  id              String             @id @default(cuid())
  organizationId  String             @map("organization_id")
  userId          String             @map("user_id")
  plannerId       String?            @map("planner_id")
  forgeProposalId String?            @map("forge_proposal_id")
  orgProjectId    String?            @map("org_project_id")
  title           String
  description     String?
  campaignType    String?            @map("campaign_type")
  status          NasaCampaignStatus @default(DRAFT)
  companyCode     String?            @unique @map("company_code")
  startDate       DateTime?          @map("start_date")
  endDate         DateTime?          @map("end_date")
  clientName      String?            @map("client_name")
  clientLogo      String?            @map("client_logo")
  color           String?            @default("#7c3aed")
  metadata        Json               @default("{}")
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")
  deletedAt       DateTime?          @map("deleted_at")

  organization  Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user          User           @relation("NasaCampaignPlannerCreatedBy", fields: [userId], references: [id])
  planner       NasaPlanner?   @relation(fields: [plannerId], references: [id], onDelete: SetNull)
  forgeProposal ForgeProposal? @relation(fields: [forgeProposalId], references: [id], onDelete: SetNull)
  orgProject    OrgProject?    @relation(fields: [orgProjectId], references: [id], onDelete: SetNull)

  onboarding                NasaCampaignOnboarding?
  events                    NasaCampaignEvent[]
  brandAssets               NasaCampaignBrandAsset[]
  tasks                     NasaCampaignTask[]
  publicAccess              NasaCampaignPublicAccess?
  posts                     NasaPlannerPost[]
  clientOnboardingProcesses ClientOnboardingProcess[]

  @@index([organizationId])
  @@index([userId])
  @@index([companyCode])
  @@map("nasa_campaign_planners")
}

model NasaCampaignOnboarding {
  id                  String    @id @default(cuid())
  campaignPlannerId   String    @unique @map("campaign_planner_id")
  stage               String    @default("forge_pending")
  forgeCompletedAt    DateTime? @map("forge_completed_at")
  onboardingStartedAt DateTime? @map("onboarding_started_at")
  notes               String?
  responsibleUserId   String?   @map("responsible_user_id")
  metadata            Json      @default("{}")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  campaignPlanner NasaCampaignPlanner @relation(fields: [campaignPlannerId], references: [id], onDelete: Cascade)
  responsibleUser User?               @relation("NasaCampaignOnboardingResponsible", fields: [responsibleUserId], references: [id])

  @@map("nasa_campaign_onboardings")
}

model NasaCampaignEvent {
  id                  String                  @id @default(cuid())
  campaignPlannerId   String                  @map("campaign_planner_id")
  eventType           NasaCampaignEventType   @map("event_type")
  title               String
  description         String?
  scheduledAt         DateTime                @map("scheduled_at")
  durationMinutes     Int                     @default(60) @map("duration_minutes")
  participants        Json                    @default("[]")
  meetingLink         String?                 @map("meeting_link")
  status              NasaCampaignEventStatus @default(SCHEDULED)
  linkedActionId      String?                 @map("linked_action_id")
  linkedAppointmentId String?                 @map("linked_appointment_id")
  createdAt           DateTime                @default(now()) @map("created_at")
  updatedAt           DateTime                @updatedAt @map("updated_at")

  campaignPlanner NasaCampaignPlanner @relation(fields: [campaignPlannerId], references: [id], onDelete: Cascade)

  @@index([campaignPlannerId])
  @@index([scheduledAt])
  @@map("nasa_campaign_events")
}

model NasaCampaignBrandAsset {
  id                String                     @id @default(cuid())
  campaignPlannerId String                     @map("campaign_planner_id")
  nboxItemId        String?                    @map("nbox_item_id")
  assetType         NasaCampaignBrandAssetType @map("asset_type")
  name              String
  url               String?
  filePath          String?                    @map("file_path")
  metadata          Json                       @default("{}")
  createdAt         DateTime                   @default(now()) @map("created_at")

  campaignPlanner NasaCampaignPlanner @relation(fields: [campaignPlannerId], references: [id], onDelete: Cascade)
  nboxItem        NBoxItem?           @relation(fields: [nboxItemId], references: [id], onDelete: SetNull)

  @@index([campaignPlannerId])
  @@map("nasa_campaign_brand_assets")
}

model NasaCampaignTask {
  id                String                   @id @default(cuid())
  campaignPlannerId String                   @map("campaign_planner_id")
  title             String
  description       String?
  assignedTo        String?                  @map("assigned_to")
  priority          NasaCampaignTaskPriority @default(MEDIUM)
  status            NasaCampaignTaskStatus   @default(PENDING)
  dueDate           DateTime?                @map("due_date")
  tags              Json                     @default("[]")
  createdAt         DateTime                 @default(now()) @map("created_at")
  updatedAt         DateTime                 @updatedAt @map("updated_at")

  campaignPlanner NasaCampaignPlanner @relation(fields: [campaignPlannerId], references: [id], onDelete: Cascade)
  assignee        User?               @relation("NasaCampaignTaskAssignee", fields: [assignedTo], references: [id])

  @@index([campaignPlannerId])
  @@map("nasa_campaign_tasks")
}

model NasaCampaignPublicAccess {
  id                String    @id @default(cuid())
  campaignPlannerId String    @unique @map("campaign_planner_id")
  accessCode        String    @unique @map("access_code")
  isActive          Boolean   @default(true) @map("is_active")
  allowedViews      Json      @default("[\"calendar\"]") @map("allowed_views")
  expiresAt         DateTime? @map("expires_at")
  lastAccessedAt    DateTime? @map("last_accessed_at")
  createdAt         DateTime  @default(now()) @map("created_at")

  campaignPlanner NasaCampaignPlanner @relation(fields: [campaignPlannerId], references: [id], onDelete: Cascade)

  @@index([accessCode])
  @@map("nasa_campaign_public_access")
}

// ─── Client Onboarding Journey ─────────────────────────────────────────────

enum ClientOnboardingStage {
  PAYMENT_CONFIRMED
  FORMS_SENT
  BRAND_FORM_DONE
  ONBOARDING_DONE
  KICKOFF_SCHEDULED
  CAMPAIGN_CREATED
  ACTIVE
}

model ClientOnboardingProcess {
  id               String                @id @default(cuid())
  organizationId   String                @map("organization_id")
  orgProjectId     String?               @map("org_project_id")
  proposalId       String?               @unique @map("proposal_id")
  leadId           String?               @map("lead_id")
  plannerId        String?               @map("planner_id")
  campaignId       String?               @map("campaign_id")
  brandFormId      String?               @map("brand_form_id")
  onboardingFormId String?               @map("onboarding_form_id")
  clientPortalCode String                @unique @map("client_portal_code")
  kickoffLink      String?               @map("kickoff_link")
  stage            ClientOnboardingStage @default(PAYMENT_CONFIRMED)

  paymentConfirmedAt DateTime? @map("payment_confirmed_at")
  formsSentAt        DateTime? @map("forms_sent_at")
  brandFormDoneAt    DateTime? @map("brand_form_done_at")
  onboardingDoneAt   DateTime? @map("onboarding_done_at")
  campaignCreatedAt  DateTime? @map("campaign_created_at")
  activatedAt        DateTime? @map("activated_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

