enum TypeAction {
  TASK
  ACTION
  MEETING
  NOTE
}

model Action {
  id          String         @id @default(cuid())
  title       String
  description String?
  score       Int            @default(0)
  isDone      Boolean        @default(false) @map("is_done")
  type        TypeAction     @default(TASK)
  priority    ActionPriority @default(NONE)
  order       Decimal        @default(0) @db.Decimal(20, 10)
  dueDate     DateTime?      @map("due_date")
  startDate   DateTime?      @map("start_date")
  endDate     DateTime?      @map("end_date")

  workspaceId String  @map("workspace_id")
  columnId    String? @map("column_id")

  trackingId     String? @map("tracking_id")
  organizationId String? @map("organization_id")
  createdBy      String  @map("created_by")
  leadId         String? @map("lead_id")
  orgProjectId   String? @map("org_project_id")

  closedAt  DateTime? @map("closed_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user         User             @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  lead         Lead?            @relation(fields: [leadId], references: [id], onDelete: SetNull)
  tracking     Tracking?        @relation(fields: [trackingId], references: [id], onDelete: SetNull)
  organization Organization?    @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  orgProject   OrgProject?      @relation(fields: [orgProjectId], references: [id], onDelete: SetNull)
  workspace    Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  column       WorkspaceColumn? @relation(fields: [columnId], references: [id], onDelete: SetNull)

  participants    ActionsUserParticipant[]
  responsibles    ActionsUserResponsible[]
  subActions      SubActions[]
  subActionGroups SubActionGroup[]

  attachments     Json           @default("[]") @map("attachments")
  links           Json           @default("[]") @map("links")
  youtubeUrl      String?        @map("youtube_url")
  coverImage      String?        @map("cover_image")
  isArchived      Boolean        @default(false) @map("is_archived")
  /// Favorito global do workspace — só admin/owner/moderador da org alternam.
  isFavorited     Boolean        @default(false) @map("is_favorited")
  history         Json           @default("[]") @map("history")
  tags            ActionTag[]
  mirrorsAsSource ActionMirror[] @relation("SourceMirror")
  mirrorOf        ActionMirror?  @relation("MirrorOf")
  sharedFrom      ActionShare[]  @relation("SharedAction")

  // Posts criados via "Criar com Planner" no popup do view-action-modal
  // (NASA Planner 2.0). Mantém o vínculo Action↔Post pra rastreabilidade
  // e auto-popular caption/title quando o popup abre.
  plannerPosts NasaPlannerPost[] @relation("ActionPlannerPosts")

  // ─── Calendário Público ─────────────────────────────────────────────
  isPublic    Boolean   @default(false) @map("is_public")
  publicSlug  String?   @unique @map("public_slug")
  publishedAt DateTime? @map("published_at")

  viewCount  Int @default(0) @map("view_count")
  likesCount Int @default(0) @map("likes_count")
  shareCount Int @default(0) @map("share_count")

  country String? @default("BR")
  state   String?
  city    String?
  address String?

  eventCategory   EventCategory? @map("event_category")
  registrationUrl String?        @map("registration_url")
  formId          String?        @map("form_id")

  isGuestDraft    Boolean @default(false) @map("is_guest_draft")
  guestDraftToken String? @unique @map("guest_draft_token")

  // ── Sistema de reivindicação/denúncia ──────────────────────
  // Quando criador rejeita um claim, evento ganha banner "ownership
  // contestado" via `isDisputed=true` (não despublica — admin decide).
  // `reportScore` acumula peso de reports PENDING; score >= threshold
  // (env CALENDAR_REPORT_SCORE_THRESHOLD, default 10) marca disputed.
  isDisputed    Boolean @default(false) @map("is_disputed")
  disputeReason String? @map("dispute_reason") // resumo curto pro banner
  reportScore   Int     @default(0) @map("report_score")

  claims  EventClaim[]
  reports EventReport[]

  likes        ActionLike[]
  favorites    ActionFavorite[]
  views        ActionView[]
  publicShares PublicActionShare[]
  reminders    ActionReminder[]

  chatMessages  ActionChatMessage[]
  chatReads     ActionChatRead[]
  chatReminders Reminder[]          @relation("ActionReminders")

  @@index([workspaceId])
  @@index([columnId])
  @@index([leadId])
  @@index([createdBy])
  @@index([isDone])
  @@index([priority])
  @@index([dueDate])
  @@index([order])
  @@index([isPublic, publishedAt])
  @@index([country, state, city])
  @@index([eventCategory])
  @@index([organizationId, isPublic, publishedAt])
  @@map("actions")
}

// ─── Calendário Público: Reivindicação e Denúncia ───────────────────────────
//
// Sistema pra controle de "uso de marca de terceiros" em eventos públicos.
// Marca legítima usa "Reivindicar este evento" → cria EventClaim → criador
// recebe email + in-app → responde aceitando (despublica) ou rejeitando
// (vira disputa, admin decide). 7 dias sem resposta → auto-despublica.
// Reports leves (denúncia rápida) acumulam score; threshold dispara flag.

enum EventClaimStatus {
  PENDING        // aguardando resposta do criador (7 dias)
  ACCEPTED       // criador aceitou — evento despublicado
  REJECTED       // criador rejeitou — virou disputa pra admin
  EXPIRED        // 7 dias sem resposta — auto-despublicado
  ADMIN_RESOLVED // admin decidiu manualmente (uphold ou dismiss)
}

model EventClaim {
  id             String @id @default(cuid())
  actionId       String @map("action_id")
  action         Action @relation(fields: [actionId], references: [id], onDelete: Cascade)
  claimantUserId String? @map("claimant_user_id")
  claimantOrgId  String? @map("claimant_org_id")
  claimantEmail  String  @map("claimant_email")
  claimantName   String  @map("claimant_name")

  // Magic-links — criador responde sem auth, claimant acompanha o status.
  responseToken String @unique @default(cuid()) @map("response_token")
  trackingToken String @unique @default(cuid()) @map("tracking_token")

  reason          String  @db.Text
  evidence        Json? // URLs de prova, descrições adicionais
  status          EventClaimStatus @default(PENDING)
  creatorResponse String? @map("creator_response") @db.Text // resposta do criador ao rejeitar
  adminNote       String? @map("admin_note") @db.Text

  expiresAt        DateTime  @map("expires_at") // createdAt + 7 dias
  resolvedAt       DateTime? @map("resolved_at")
  resolvedByUserId String?   @map("resolved_by_user_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([actionId, status])
  @@index([expiresAt, status]) // pra Inngest job de auto-resolve
  @@index([claimantEmail])
  @@map("event_claims")
}

enum EventReportReason {
  BRAND_MISUSE
  FAKE
  OFFENSIVE
  DUPLICATE
  OTHER
}

enum EventReportStatus {
  PENDING
  RESOLVED
  DISMISSED
}

model EventReport {
  id             String  @id @default(cuid())
  actionId       String  @map("action_id")
  action         Action  @relation(fields: [actionId], references: [id], onDelete: Cascade)
  reporterUserId String? @map("reporter_user_id")
  reporterEmail  String? @map("reporter_email")
  reporterIp     String? @map("reporter_ip") // anti-spam, rate-limit

  reason EventReportReason
  detail String? @db.Text

  // Peso do report: 1 padrão, 5 quando reporter pertence a org verificada
  // ou é admin. Soma de PENDING vai pra Action.reportScore — threshold
  // (env CALENDAR_REPORT_SCORE_THRESHOLD, default 10) marca isDisputed.
  weight Int @default(1)

  status           EventReportStatus @default(PENDING)
  adminNote        String?           @map("admin_note") @db.Text
  resolvedByUserId String?           @map("resolved_by_user_id")
  resolvedAt       DateTime?         @map("resolved_at")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([actionId, status])
  @@index([status, createdAt])
  @@index([reporterIp]) // rate-limit lookups
  @@map("event_reports")
}

// ─── Calendário Público: Likes / Views / Shares / Reminders ─────────────────

model ActionLike {
  id          String   @id @default(cuid())
  actionId    String   @map("action_id")
  userId      String?  @map("user_id")
  fingerprint String?
  createdAt   DateTime @default(now()) @map("created_at")

  action Action @relation(fields: [actionId], references: [id], onDelete: Cascade)
  user   User?  @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@unique([actionId, userId])
  @@unique([actionId, fingerprint])
  @@index([actionId])
  @@index([userId])
  @@map("action_likes")
}

model ActionFavorite {
  id        String   @id @default(cuid())
  actionId  String   @map("action_id")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  action Action @relation(fields: [actionId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([actionId, userId])
  @@index([userId])
  @@index([actionId])
  @@map("action_favorites")
}

model ActionView {
  id          String   @id @default(cuid())
  actionId    String   @map("action_id")
  fingerprint String
  userId      String?  @map("user_id")
  referrer    String?
  sharerToken String?  @map("sharer_token")
  createdAt   DateTime @default(now()) @map("created_at")

  action Action @relation(fields: [actionId], references: [id], onDelete: Cascade)

  @@unique([actionId, fingerprint])
  @@index([actionId, createdAt])
  @@index([sharerToken])
  @@map("action_views")
}

model PublicActionShare {
  id           String   @id @default(cuid())
  actionId     String   @map("action_id")
  sharerUserId String?  @map("sharer_user_id")
  sharerToken  String   @unique @map("sharer_token")
  platform     String?
  clicks       Int      @default(0)
  createdAt    DateTime @default(now()) @map("created_at")

  action     Action @relation(fields: [actionId], references: [id], onDelete: Cascade)
  sharerUser User?  @relation("PublicActionShareSharer", fields: [sharerUserId], references: [id], onDelete: SetNull)

  @@index([actionId])
  @@index([sharerUserId])
  @@map("public_action_shares")
}

model ActionReminder {
  id          String          @id @default(cuid())
  actionId    String          @map("action_id")
  userId      String?         @map("user_id")
  phoneNumber String          @map("phone_number")
  channel     ReminderChannel @default(WHATSAPP)
  remindAt    DateTime        @map("remind_at")
  sent        Boolean         @default(false)
  sentAt      DateTime?       @map("sent_at")
  consentAt   DateTime        @default(now()) @map("consent_at")
  createdAt   DateTime        @default(now()) @map("created_at")

  action Action @relation(fields: [actionId], references: [id], onDelete: Cascade)
  user   User?  @relation("ActionReminderUser", fields: [userId], references: [id], onDelete: SetNull)

  @@index([actionId, sent])
  @@index([remindAt, sent])
  @@map("action_reminders")
}

model ActionChatMessage {
  id              String   @id @default(cuid())
  actionId        String   @map("action_id")
  body            String?
  mediaUrl        String?  @map("media_url")
  mediaType       String?  @map("media_type")
  mimetype        String?
  fileName        String?  @map("file_name")
  quotedMessageId String?  @map("quoted_message_id")
  senderId        String   @map("sender_id")
  senderName      String?  @map("sender_name")
  isEdited        Boolean  @default(false) @map("is_edited")
  isDeleted       Boolean  @default(false) @map("is_deleted")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  action        Action              @relation(fields: [actionId], references: [id], onDelete: Cascade)
  sender        User                @relation("ActionChatSender", fields: [senderId], references: [id], onDelete: Cascade)
  quotedMessage ActionChatMessage?  @relation("QuotedActionChat", fields: [quotedMessageId], references: [id], onDelete: SetNull)
  quotes        ActionChatMessage[] @relation("QuotedActionChat")

  @@index([actionId, createdAt])
  @@index([senderId])
  @@map("action_chat_messages")
}

model ActionChatRead {
  id         String   @id @default(cuid())
  actionId   String   @map("action_id")
  userId     String   @map("user_id")
  lastReadAt DateTime @default(now()) @map("last_read_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  action Action @relation(fields: [actionId], references: [id], onDelete: Cascade)
  user   User   @relation("ActionChatReader", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([actionId, userId])
  @@index([userId])
  @@map("action_chat_reads")
}

model SubActionUserResponsible {
  id          String @id @default(cuid())
  userId      String @map("user_id")
  subActionId String @map("sub_action_id")

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  subAction SubActions @relation(fields: [subActionId], references: [id], onDelete: Cascade)

  @@unique([userId, subActionId])
  @@map("sub_actions_user_responsible")
}

model SubActions {
  id           String                     @id @default(cuid())
  title        String
  description  String?
  isDone       Boolean                    @default(false) @map("is_done")
  finishDate   DateTime?                  @map("finish_date")
  createdAt    DateTime                   @default(now()) @map("created_at")
  actionId     String                     @map("action_id")
  groupId      String?                    @map("group_id")
  order        Int                        @default(0)
  action       Action                     @relation(fields: [actionId], references: [id], onDelete: Cascade)
  group        SubActionGroup?            @relation(fields: [groupId], references: [id], onDelete: SetNull)
  responsibles SubActionUserResponsible[]

  @@index([actionId])
  @@index([groupId])
  @@index([isDone])
  @@index([finishDate])
  @@map("sub_action")
}

model SubActionGroup {
  id         String       @id @default(cuid())
  name       String
  order      Int          @default(0)
  isOpen     Boolean      @default(true) @map("is_open")
  actionId   String       @map("action_id")
  action     Action       @relation(fields: [actionId], references: [id], onDelete: Cascade)
  subActions SubActions[]
  createdAt  DateTime     @default(now()) @map("created_at")

  @@index([actionId])
  @@map("sub_action_groups")
}

// ─────────────────────────────────────────────
// AUTOMAÇÕES
// ─────────────────────────────────────────────

model Workflow {
  id          String   @id @default(cuid())
  name        String
  description String?
  userId      String?  @map("user_id")
  trackingId  String?  @map("tracking_id")
  workspaceId String?  @map("workspace_id")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user      User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  tracking  Tracking?  @relation(fields: [trackingId], references: [id], onDelete: Cascade)
  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  nodes       Node[]
  connections Connection[]

  @@index([trackingId])
  @@index([workspaceId])
  @@map("workflows")
}

enum NodeType {
  // Gatilhos
  INITIAL
  MANUAL_TRIGGER
  NEW_LEAD
  MOVE_LEAD_STATUS
  LEAD_TAGGED
  AI_FINISHED
  FIRST_CHAT_INTERACTION
  // Gatilho time-based: dispara quando o lead fica X minutos sem mandar
  // mensagem nova (computado a partir de `Lead.lastInboundAt`).
  LAST_INBOUND_TIMEOUT
  // LEAD_UNTAGGED

  // Execuções
  HTTP_REQUEST
  MOVE_LEAD
  SEND_MESSAGE
  WAIT
  WIN_LOSS
  TAG
  TEMPERATURE
  RESPONSIBLE

  // Utils
  FILTER_LEAD

  // ─── Workspace (Actions/Kanban) ─────────────────
  // Utils
  WS_INITIAL

  // Gatilhos
  WS_MANUAL_TRIGGER
  WS_ACTION_CREATED
  WS_ACTION_MOVED_COLUMN
  WS_ACTION_TAGGED
  WS_ACTION_COMPLETED
  WS_ACTION_PARTICIPANT_ADDED

  // Execuções
  WS_CREATE_ACTION
  WS_MOVE_ACTION
  WS_ADD_TAG_ACTION
  WS_ADD_PARTICIPANT
  WS_SET_RESPONSIBLE
  WS_CREATE_SUB_ACTION
  WS_SEND_MESSAGE_PARTICIPANTS
  WS_SEND_EMAIL_PARTICIPANTS
  WS_ARCHIVE_ACTION
  WS_WAIT
  WS_HTTP_REQUEST
  WS_FILTER
}

model Node {
  id         String   @id @default(cuid())
  workflowId String   @map("workflow_id")
  name       String
  type       NodeType
  position   Json
  data       Json     @default("{}")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  workflow Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  outputConnections Connection[] @relation("FromNode")
  inputConnections  Connection[] @relation("ToNode")

  @@map("nodes")
}

model Connection {
  id         String   @id @default(cuid())
  workflowId String   @map("workflow_id")
  fromNodeId String   @map("from_node_id")
  toNodeId   String   @map("to_node_id")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  fromOutput String   @default("main")
  toInput    String   @default("main")

  workflow Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  fromNode Node     @relation("FromNode", fields: [fromNodeId], references: [id], onDelete: Cascade)
  toNode   Node     @relation("ToNode", fields: [toNodeId], references: [id], onDelete: Cascade)

  @@unique([fromNodeId, toNodeId, fromOutput, toInput])
  @@map("connections")
}

// ─────────────────────────────────────────────
// FORMULÁRIO
// ─────────────────────────────────────────────

model Form {
  id             String   @id @default(cuid())
  userId         String   @map("user_id")
  organizationId String
  name           String
  description    String?
  jsonBlock      String   @default("[]")
  published      Boolean  @default(false)
  content        String
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  settingsId     String?  @unique

  views     Int @default(0)
  responses Int @default(0)

  isTemplate                Boolean @default(false) @map("is_template")
  templateMarkedByModerator Boolean @default(false) @map("template_marked_by_moderator")

  createdBy       User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  formSubmissions FormResponses[]
  shareUrl        String          @unique @map("share_url")

  organization Organization  @relation(fields: [organizationId], references: [id])
  settings     FormSettings?

  onboardingBrandForms      ClientOnboardingProcess[] @relation("OnboardingBrandForm")
  onboardingOnboardingForms ClientOnboardingProcess[] @relation("OnboardingOnboardingForm")

  isPublicOnSpace Boolean @default(false) @map("is_public_on_space")

  @@map("forms")
}

model FormSettings {
  id              String   @id @default(cuid())
  primaryColor    String
  backgroundColor String
  backgroundImage String?  @map("background_image")
  createdAt       DateTime @default(now())
  updateAt        DateTime @default(now()) @updatedAt
  trackingId      String?  @map("tracking_id")
  statusId        String?  @map("status_id")
  formId          String   @unique
  redirectUrl     String?  @map("redirect_url")
  idPixel         String?  @map("id_pixel")
  idTagManager    String?  @map("id_tag_manager")
  needLogin       Boolean  @default(true) @map("need_login")
  showName        Boolean  @default(true) @map("show_name")
  showEmail       Boolean  @default(true) @map("show_email")
  showPhone       Boolean  @default(true) @map("show_phone")
  finishMessage   String   @default("Obrigado por seu cadastro!") @map("finish_message")
  stepMode        String   @default("off") @map("step_mode")
  nextButtonLabel String   @default("Próximo") @map("next_button_label")
  progressMascots Json     @default("[]") @map("progress_mascots")
  nextButtonAction Json    @default("{\"type\":\"next_block\"}") @map("next_button_action")
  whatsappChats    Json    @default("[]") @map("whatsapp_chats")
  whatsappMessage  String? @map("whatsapp_message")

  tracking Tracking? @relation(fields: [trackingId], references: [id], onDelete: SetNull)
  status   Status?   @relation(fields: [statusId], references: [id], onDelete: SetNull)
  form     Form      @relation(fields: [formId], references: [id], onDelete: Cascade)

  @@map("form_settings")
}

model FormResponses {
  id           String    @id @default(cuid())
  formId       String    @map("form_id")
  createdAt    DateTime  @default(now()) @map("created_at")
  /// NULL = resposta iniciada via save-partial mas não finalizada;
  /// preenchido = enviada via submit. Cron detect-form-abandoned varre
  /// onde completedAt IS NULL AND createdAt < now() - N min.
  completedAt  DateTime? @map("completed_at")
  jsonResponse Json      @default("[]")
  leadId       String?   @map("lead_id")
  lead         Lead?     @relation(fields: [leadId], references: [id])

  // Título customizado da resposta (ex: "#00123" — número da O.S).
  // - `label` é exibido como sufixo após o nome do form: "Checklist · #00123".
  // - Auto-derivado de um bloco do form marcado com
  //   `attributes.useAsResponseLabel === true`.
  // - Se `labelManuallyEdited === true`, saves seguintes não sobrescrevem
  //   (manual prevalece). Limpar manualmente devolve ao modo automático.
  label               String?  @map("label")
  labelManuallyEdited Boolean  @default(false) @map("label_manually_edited")

  form Form @relation(fields: [formId], references: [id], onDelete: Cascade)

  @@index([completedAt])
  @@map("form_responses")
}

// ─────────────────────────────────────────────
// CHAT
// ─────────────────────────────────────────────

enum MessageChannel {
  WHATSAPP
  INSTAGRAM
  FACEBOOK
}

model Conversation {
  id            String   @id @default(cuid())
  createdAt     DateTime @default(now()) @map("created_at")
  lastMessageAt DateTime @updatedAt @map("last_message_at")
  name          String?
  isGroup       Boolean  @default(false)

  remoteJid     String         @map("remote_jid")
  profilePicUrl String?        @map("profile_pic_url")
  isActive      Boolean        @default(true) @map("is_active")
  channel       MessageChannel @default(WHATSAPP) @map("channel")

  // Marca a 1ª mensagem enviada pelo usuário do app (fromMe=true) nesta
  // conversa. Usado para disparar o gatilho FIRST_CHAT_INTERACTION de forma
  // atômica via updateMany condicional — evita race em envios concorrentes.
  firstUserMessageAt DateTime? @map("first_user_message_at")

  lead       Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  leadId     String   @unique @map("lead_id")
  trackingId String   @map("tracking_id")
  tracking   Tracking @relation(fields: [trackingId], references: [id], onDelete: Cascade)

  lastMessageId String?  @unique @map("last_message_id")
  lastMessage   Message? @relation(fields: [lastMessageId], references: [id])

  messages  Message[]  @relation("Messages")
  reminders Reminder[]

  @@unique([leadId, trackingId])
  @@unique([remoteJid, trackingId])
  @@index([isActive])
  @@index([lastMessageAt])
  @@index([trackingId])
  @@map("conversations")
}

enum MessageStatus {
  SENT
  SEEN
  DELETED
}

model Message {
  id        String   @id @default(cuid())
  body      String?
  createdAt DateTime @default(now()) @map("created_at")

  messageId String        @unique @map("message_id")
  fromMe    Boolean       @default(false) @map("from_me")
  status    MessageStatus @default(SENT)
  seen      Boolean       @default(false)

  mediaUrl     String? @map("media_url")
  mediaType    String? @map("media_type")
  mediaCaption String? @map("media_caption")
  mimetype     String?
  fileName     String? @map("file_name")

  latitude  Float? @map("latitude")
  longitude Float? @map("longitude")

  quotedMessageId String?   @map("quoted_message_id")
  quotedMessage   Message?  @relation("QuotedMessages", fields: [quotedMessageId], references: [id], onDelete: SetNull)
  quotes          Message[] @relation("QuotedMessages")
  conversationId  String
  senderId        String?
  senderName      String?

  conversation Conversation  @relation("Messages", fields: [conversationId], references: [id], onDelete: Cascade)
  LastMessage  Conversation?

  @@index([conversationId, createdAt])
  @@index([status])
  @@index([fromMe])
  @@map("messages")
}

enum WhatsAppInstanceStatus {
  CONNECTED
  DISCONNECTED
}

model WhatsAppInstance {
  id             String                 @id @default(cuid())
  instanceName   String                 @map("instance_name")
  instanceId     String                 @unique @map("instance_id")
  apiKey         String                 @unique @map("api_key") // Token
  baseUrl        String                 @map("base_url") // URL
  status         WhatsAppInstanceStatus @default(DISCONNECTED)
  qrCode         String?                @map("qr_code") // Base64 do QR Code
  phoneNumber    String?                @map("phone_number") // Número conectado
  profileName    String?                @map("profile_name")
  profilePicUrl  String?                @map("profile_pic_url")
  organizationId String                 @map("organization_id")
  trackingId     String                 @unique @map("tracking_id")
  webhookUrl     String?                @map("webhook_url")
  isActive       Boolean                @default(true) @map("is_active")
  lastSyncAt     DateTime?              @map("last_sync_at")
  createdAt      DateTime               @default(now()) @map("created_at")
  updatedAt      DateTime               @updatedAt @map("updated_at")
  isBusiness     Boolean                @default(false) @map("is_business")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  tracking     Tracking     @relation(fields: [trackingId], references: [id])

  @@index([organizationId])
  @@index([status])
  @@map("whatsapp_instances")
}

// ─────────────────────────────────────────────
// REMINDERS
// ─────────────────────────────────────────────

enum ReminderRecurrenceType {
  ONCE
  WEEKLY
  BIWEEKLY
  MONTHLY
}

model Reminder {
  id              String @id @default(cuid())
  createdByUserId String @map("created_by_user_id")

  message        String
  recurrenceType ReminderRecurrenceType @map("recurrence_type")
  dayOfMonth     Int?                   @map("day_of_month")
  remindTime     String                 @map("remind_time")
  notifyPhone    String?                @map("notify_phone")

  nextRemindAt DateTime? @map("next_remind_at")
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  leadId         String? @map("lead_id")
  conversationId String? @map("conversation_id")
  trackingId     String? @map("tracking_id")
  actionId       String? @map("action_id")

  lead         Lead?                @relation(fields: [leadId], references: [id], onDelete: SetNull)
  conversation Conversation?        @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  tracking     Tracking?            @relation(fields: [trackingId], references: [id], onDelete: SetNull)
  action       Action?              @relation("ActionReminders", fields: [actionId], references: [id], onDelete: SetNull)
  createdBy    User                 @relation("ReminderCreatedBy", fields: [createdByUserId], references: [id])
  occurrences  ReminderOccurrence[]

  @@index([nextRemindAt, isActive])
  @@index([conversationId])
  @@index([leadId])
  @@index([trackingId])
  @@index([actionId, isActive])
  @@map("reminders")
}

model ReminderOccurrence {
  id          String    @id @default(cuid())
  reminderId  String    @map("reminder_id")
  scheduledAt DateTime  @map("scheduled_at")
  sent        Boolean   @default(false)
  sentAt      DateTime? @map("sent_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  reminder Reminder @relation(fields: [reminderId], references: [id], onDelete: Cascade)

  @@index([reminderId])
  @@index([scheduledAt, sent])
  @@map("reminder_occurrences")
}

model InsightShares {
  id             String       @id @default(cuid())
  name           String
  token          String       @unique @default(cuid())
  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  filters        Json         @default("{}")
  settings       Json         @default("{}")
  userId         String       @map("user_id")
  createdBy      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now()) @map("created_at")

  @@map("insight_shares")
}

// ─────────────────────────────────────────────
// AGENDA
// ─────────────────────────────────────────────

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

model Agenda {
  id             String   @id @default(cuid())
  name           String
  description    String?
  slug           String
  isActive       Boolean  @default(true) @map("is_active")
  slotDuration   Int      @default(30) @map("slot_duration")
  trackingId     String   @map("tracking_id")
  statusId       String?  @map("status_id")
  organizationId String   @map("organization_id")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  tracking     Tracking     @relation(fields: [trackingId], references: [id], onDelete: Cascade)
  status       Status?      @relation(fields: [statusId], references: [id], onDelete: SetNull)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  responsibles       AgendaResponsible[]
  availabilities     AgendaAvailability[]
  appointments       Appointment[]
  publicChatSessions PublicChatSession[]
  dateOverrides      AgendaDateOverride[]
  dateAvailabilities AgendaDateAvailability[]
  tags               Tag[]

  @@unique([slug, organizationId])
  @@index([trackingId])
  @@index([statusId])
  @@index([organizationId])
  @@index([isActive])
  @@map("agendas")
}

// Responsáveis pela agenda (um ou mais usuários)
model AgendaResponsible {
  id        String   @id @default(cuid())
  agendaId  String   @map("agenda_id")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  agenda Agenda @relation(fields: [agendaId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([agendaId, userId])
  @@index([agendaId])
  @@index([userId])
  @@map("agenda_responsibles")
}

// Disponibilidade por dia da semana (ex: Segunda, 8h–12h)
model AgendaAvailability {
  id        String    @id @default(cuid())
  agendaId  String    @map("agenda_id")
  dayOfWeek DayOfWeek @map("day_of_week")
  isActive  Boolean   @default(true) @map("is_active")

  agenda    Agenda                 @relation(fields: [agendaId], references: [id], onDelete: Cascade)
  timeSlots AvailabilityTimeSlot[]

  @@unique([agendaId, dayOfWeek])
  @@index([agendaId])
  @@map("agenda_availabilities")
}

// Intervalos de horário dentro de um dia (ex: 8h–12h, 14h–18h)
model AvailabilityTimeSlot {
  id             String @id @default(cuid())
  availabilityId String @map("availability_id")
  startTime      String @map("start_time") // "08:00"
  endTime        String @map("end_time") // "12:00"
  order          Int    @default(0)

  availability AgendaAvailability @relation(fields: [availabilityId], references: [id], onDelete: Cascade)

  @@index([availabilityId])
  @@map("availability_time_slots")
}

// Agendamentos realizados
enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  NO_SHOW
  DONE
}

// Tipo de reunião do agendamento
enum MeetingType {
  ONLINE
  IN_PERSON
}

model Appointment {
  id          String            @id @default(cuid())
  title       String?
  notes       String?
  startsAt    DateTime          @map("starts_at")
  endsAt      DateTime          @map("ends_at")
  status      AppointmentStatus @default(PENDING)
  meetingType MeetingType       @default(ONLINE) @map("meeting_type")
  gcalEventId String?           @map("gcal_event_id") // ID do evento criado no Google Calendar
  cancelledBy String?           @map("cancelled_by") // "CLIENT" | "SYSTEM"
  agendaId    String            @map("agenda_id")
  leadId      String?           @map("lead_id")
  userId      String?           @map("user_id")
  trackingId  String?           @map("tracking_id")
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")

  orgProjectId String? @map("org_project_id")

  agenda     Agenda      @relation(fields: [agendaId], references: [id], onDelete: Cascade)
  lead       Lead?       @relation(fields: [leadId], references: [id], onDelete: SetNull)
  user       User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  tracking   Tracking?   @relation(fields: [trackingId], references: [id], onDelete: SetNull)
  orgProject OrgProject? @relation(fields: [orgProjectId], references: [id], onDelete: SetNull)

  @@index([agendaId])
  @@index([leadId])
  @@index([userId])
  @@index([startsAt])
  @@index([status])
  @@map("appointments")
}

// ─────────────────────────────────────────────
// DISPONIBILIDADE POR DATA ESPECÍFICA
// ─────────────────────────────────────────────

// Disponibilidade para uma data específica (sobrepõe o semanal)
model AgendaDateAvailability {
  id        String   @id @default(cuid())
  agendaId  String   @map("agenda_id")
  date      String // YYYY-MM-DD
  createdAt DateTime @default(now()) @map("created_at")

  agenda    Agenda                       @relation(fields: [agendaId], references: [id], onDelete: Cascade)
  timeSlots AgendaDateAvailabilitySlot[]

  @@unique([agendaId, date])
  @@index([agendaId])
  @@map("agenda_date_availabilities")
}

// Intervalos de horário dentro de uma disponibilidade por data específica
model AgendaDateAvailabilitySlot {
  id                 String @id @default(cuid())
  dateAvailabilityId String @map("date_availability_id")
  startTime          String @map("start_time") // "08:00"
  endTime            String @map("end_time") // "12:00"
  order              Int    @default(0)

  dateAvailability AgendaDateAvailability @relation(fields: [dateAvailabilityId], references: [id], onDelete: Cascade)

  @@index([dateAvailabilityId])
  @@map("agenda_date_availability_slots")
}

// ─────────────────────────────────────────────
// CHAT PÚBLICO DE AGENDAMENTO
// ─────────────────────────────────────────────

// Sessão de chat público — criada quando o cliente abre o chat da agenda.
// Não requer autenticação. Expira em 24h.
model PublicChatSession {
  id            String   @id @default(cuid())
  agendaId      String   @map("agenda_id")
  orgSlug       String   @map("org_slug")
  agendaSlug    String   @map("agenda_slug")
  appointmentId String?  @map("appointment_id")
  createdAt     DateTime @default(now()) @map("created_at")
  expiresAt     DateTime @map("expires_at")

  // Auditoria de segurança
  ipAddress String? @map("ip_address")
  userAgent String? @map("user_agent")

  agenda Agenda @relation(fields: [agendaId], references: [id], onDelete: Cascade)

  @@index([agendaId])
  @@index([expiresAt])
  @@map("public_chat_sessions")
}

// ─────────────────────────────────────────────
// EXCEÇÕES DE DATA (bloqueios / disponibilidades pontuais)
// ─────────────────────────────────────────────

// Bloqueia ou desbloqueia uma data específica, sobrepondo a disponibilidade semanal.
model AgendaDateOverride {
  id        String   @id @default(cuid())
  agendaId  String   @map("agenda_id")
  date      String // YYYY-MM-DD
  isBlocked Boolean  @default(true) @map("is_blocked")
  createdAt DateTime @default(now()) @map("created_at")

  agenda Agenda @relation(fields: [agendaId], references: [id], onDelete: Cascade)

  @@unique([agendaId, date])
  @@index([agendaId])
  @@map("agenda_date_overrides")
}

