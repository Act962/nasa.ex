generator client {
  provider      = "prisma-client"
  output        = "../src/generated/prisma"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id                    String    @id @default(cuid())
  name                  String
  email                 String
  emailVerified         Boolean   @default(false)
  nickname              String?
  phone                 String?
  image                 String?
  isSystemAdmin         Boolean   @default(false) @map("is_system_admin")
  isActive              Boolean   @default(true) @map("is_active")
  onboardingCompletedAt DateTime? @map("onboarding_completed_at")
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @default(now()) @updatedAt
  sessions              Session[]
  accounts              Account[]

  members                            Member[]
  invitations                        Invitation[]
  inviteLinksCreated                 OrganizationInviteLink[]     @relation("InviteLinksCreated")
  trackings                          TrackingParticipant[]
  leadHistories                      LeadHistory[]
  participantOnActions               ActionsUserParticipant[]
  responsibleOnActions               ActionsUserResponsible[]
  actions                            Action[]
  responsibleOnSubActions            SubActionUserResponsible[]
  responsibleOnLeads                 Lead[]                       @relation("LeadResponsible")
  worflows                           Workflow[]
  forms                              Form[]
  leadFiles                          LeadFile[]
  insightShares                      InsightShares[]
  savedInsightReports                SavedInsightReport[]
  savedReportCompares                SavedReportCompare[]
  insightLayoutsUpdated              OrganizationInsightLayout[]  @relation("OrgInsightLayoutUpdater")
  agendaResponsibles                 AgendaResponsible[]
  appointments                       Appointment[]
  trackingConsultants                TrackingConsultant[]
  forgeProductsCreated               ForgeProduct[]               @relation("ForgeProductCreatedBy")
  forgeProposalsResp                 ForgeProposal[]              @relation("ForgeProposalResponsible")
  forgeProposalsCreated              ForgeProposal[]              @relation("ForgeProposalCreatedBy")
  forgeContractsCreated              ForgeContract[]              @relation("ForgeContractCreatedBy")
  forgeTemplatesCreated              ForgeContractTemplate[]      @relation("ForgeTemplateCreatedBy")
  nboxFoldersCreated                 NBoxFolder[]                 @relation("NBoxFolderCreatedBy")
  nboxItemsCreated                   NBoxItem[]                   @relation("NBoxItemCreatedBy")
  nasaPlannerPostsCreated            NasaPlannerPost[]            @relation("NasaPlannerPostCreatedBy")
  actionSharesRequested              ActionShare[]                @relation("ShareRequester")
  workspacesCreated                  Workspace[]
  workspacesMembers                  WorkspaceMember[]
  userNotifications                  UserNotification[]
  notificationPrefs                  UserNotificationPreference[]
  sidebarPrefs                       UserSidebarPreference[]
  spacePoints                        UserSpacePoint[]
  memberStarBudgets                  MemberStarBudget[]
  paymentEntriesCreated              PaymentEntry[]               @relation("PaymentEntryCreatedBy")
  paymentAccess                      PaymentAccess[]              @relation("PaymentAccessUser")
  paymentAccessGranted               PaymentAccess[]              @relation("PaymentAccessAuthorizer")
  nasaCampaignPlannersCreated        NasaCampaignPlanner[]        @relation("NasaCampaignPlannerCreatedBy")
  nasaCampaignOnboardingsResponsible NasaCampaignOnboarding[]     @relation("NasaCampaignOnboardingResponsible")
  nasaCampaignTasksAssigned          NasaCampaignTask[]           @relation("NasaCampaignTaskAssignee")
  supportTickets                     SupportTicket[]
  stripeCustomerId                   String?                      @map("stripe_customer_id")

  linnkerPages           LinnkerPage[]
  spaceStation           SpaceStation?
  stationAccessRequests  StationAccessRequest[]
  worldTemplates         WorldTemplate[]
  avatarTemplates        AvatarTemplate[]
  connectionsAsUser      UserConnection[]       @relation("UserConnectionsAsUser")
  connectionsAsConnected UserConnection[]       @relation("UserConnectionsAsConnected")
  nasaPages              NasaPage[]
  actionLikes            ActionLike[]
  actionFavorites        ActionFavorite[]
  publicActionShares     PublicActionShare[]    @relation("PublicActionShareSharer")
  actionReminders        ActionReminder[]       @relation("ActionReminderUser")
  actionChatMessages     ActionChatMessage[]    @relation("ActionChatSender")
  actionChatReads        ActionChatRead[]       @relation("ActionChatReader")

  profileCard                    UserProfileCard?
  orgRoles                       OrgRole[]
  orgFollows                     OrgFollow[]
  companyReviews                 CompanyReview[]
  companyPosts                   CompanyPost[]
  companyPostComments            CompanyPostComment[]
  spaceHelpProgress              SpaceHelpProgress[]
  spaceHelpBadges                UserSpaceHelpBadge[]
  nasaRouteCoursesCreated        NasaRouteCourse[]       @relation("NasaRouteCreatorUser")
  nasaRouteEnrollments           NasaRouteEnrollment[]
  nasaRouteProgress              NasaRouteProgress[]
  nasaRouteFreeAccess            NasaRouteFreeAccess[]   @relation("NasaRouteFreeAccessUser")
  nasaRouteFreeAccessGranted     NasaRouteFreeAccess[]   @relation("NasaRouteFreeAccessGrantor")
  nasaRouteCertificates          NasaRouteCertificate[]
  nasaRouteVideoUploads          NasaRouteVideoUpload[]
  pendingCoursePurchasesRedeemed PendingCoursePurchase[] @relation("PendingCoursePurchaseRedeemer")
  pendingCoursePurchases         PendingCoursePurchase[] @relation("PendingCoursePurchaseUser")
  routerPaymentSettingsUpdated   RouterPaymentSettings[] @relation("RouterPaymentSettingsUpdater")
  remindersCreated               Reminder[]              @relation("ReminderCreatedBy")

  // ── NASA Partner ──
  referralLink                  PartnerReferralLink?
  partner                       Partner?
  partnerReferralsCreated       PartnerReferral[]     @relation("PartnerReferralsAsPartner")
  partnerReferralsAttachedByMe  PartnerReferral[]     @relation("PartnerReferralsAttachedByAdmin")
  partnerTermsVersionsPublished PartnerTermsVersion[] @relation("PartnerTermsVersionPublisher")
  partnerTierHistoryTriggered   PartnerTierHistory[]  @relation("PartnerTierHistoryTrigger")
  partnerPayoutsMarkedPaid      PartnerPayout[]       @relation("PartnerPayoutPaidBy")

  metaAccountAccess MemberMetaAccountAccess[]

  // Meta Ads MCP — autorização do user pra usar Astro IA Meta Ads
  metaMcpAuthorizationsAuthorized MetaMcpAuthorization[] @relation("McpAuthorizedUser")
  metaMcpAuthorizationsGranted    MetaMcpAuthorization[] @relation("McpAuthorizedBy")
  metaAdsPendingActions           MetaAdsPendingAction[]

  // Insights — jornada do lead
  leadJourneyEventsActed LeadJourneyEvent[] @relation("LeadJourneyEventActor")

  // ── ASTRO (Agentes IA) ──
  aiSessions      AiSession[]
  aiKnowledgeMade AiKnowledge[] @relation("AiKnowledgeCreatedBy")

  @@unique([email])
  @@map("user")
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  activeOrganizationId String?

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt

  @@index([identifier])
  @@map("verification")
}

model Organization {
  id           String   @id @default(cuid())
  name         String
  slug         String
  logo         String?
  createdAt    DateTime
  metadata     String?
  companyCode  String?  @unique @map("company_code")
  companyNiche String?  @map("company_niche")
  companyCep   String?  @map("company_cep")

  // ── STARS ──────────────────────────────────
  planId               String?   @map("plan_id")
  starsBalance         Int       @default(0) @map("stars_balance")
  starsBonusBalance    Int       @default(0) @map("stars_bonus_balance")
  // Saldo de bônus (welcome, promoções) — não pode pagar curso no NASA Router,
  // mas pode ser consumido por integrações (Planner IA, Command IA, APP_CHARGE/SETUP).
  starsCycleStart      DateTime? @map("stars_cycle_start")
  // ── Grace period / suspensão (pay-per-use) ────────────────
  // Quando saldo zera, `starsGraceStartedAt` é setado. Org tem 15 dias
  // pra recarregar. Cron `stars-grace-period-monitor` notifica em dias
  // 1/3/7/12/14 e seta `starsSuspendedAt` em dia 15+. Suspensão zera o
  // acesso a todas as procedures que cobram via `requireStarsMiddleware`.
  starsGraceStartedAt  DateTime? @map("stars_grace_started_at")
  starsSuspendedAt     DateTime? @map("stars_suspended_at")
  // Anti-spam de notificações pós-débito (1 dispatch/dia/severidade).
  starsLastAlertAt     DateTime? @map("stars_last_alert_at")
  starsAlertConfig     Json      @default("{}") @map("stars_alert_config")
  starDistributionMode String    @default("org") @map("star_distribution_mode")
  // "org"    = pool compartilhado (padrão)
  // "equal"  = dividido igualmente entre usuários ativos
  // "custom" = orçamento personalizado por usuário

  // Intervalo (segundos) entre heartbeats do HeartbeatProvider. Owner/master
  // pode alternar entre 60 (padrão, menos tráfego) e 30 (granularidade maior).
  heartbeatIntervalSeconds Int @default(60) @map("heartbeat_interval_seconds")

  // ── Compartilhamento público do Calendário Workspace ──────
  // Quando enabled=true E expiresAt > now(), qualquer pessoa com slug+token
  // acessa o calendário consolidado via /calendario/equipe/<slug>/<token>.
  // Token nasce com expiração de 1h; pode ser rotacionado a qualquer momento.
  // Detalhes completos pra membros logados; cards minimais pros demais.
  calendarPublicEnabled   Boolean   @default(false) @map("calendar_public_enabled")
  calendarPublicToken     String?   @unique @map("calendar_public_token")
  calendarPublicExpiresAt DateTime? @map("calendar_public_expires_at")
  calendarPublicEnabledAt DateTime? @map("calendar_public_enabled_at")
  calendarPublicEnabledBy String?   @map("calendar_public_enabled_by")
  // Audit do aceite do disclaimer pra requisitos de compliance.
  calendarPublicConsentAt DateTime? @map("calendar_public_consent_at")

  // ── Verificação de Marca ──────────────────────────────────
  // Usado pelo sistema de reivindicação de eventos públicos (Action.isPublic).
  // Org verificada: reports daquela org pesam 5 (vs 1 padrão) e ganha badge
  // visual nos eventos. Verificação é manual via admin por enquanto — não há
  // fluxo de "solicitar verificação" automático.
  isVerified Boolean   @default(false) @map("is_verified")
  verifiedAt DateTime? @map("verified_at")
  verifiedBy String?   @map("verified_by") // userId do admin que verificou

  members                Member[]
  invitations            Invitation[]
  inviteLinks            OrganizationInviteLink[]
  trackings              Tracking[]
  tags                   Tag[]
  whatsappInstances      WhatsAppInstance[]
  actions                Action[]
  insightShares          InsightShares[]
  agendas                Agenda[]
  widgets                Widget[]
  platformIntegrations   PlatformIntegration[]
  forgeProducts          ForgeProduct[]
  forgeProposals         ForgeProposal[]
  forgeContracts         ForgeContract[]
  forgeTemplates         ForgeContractTemplate[]
  forgeSettings          ForgeSettings?
  plan                   Plan?                      @relation(fields: [planId], references: [id], onDelete: SetNull)
  starTransactions       StarTransaction[]
  workspaceIntegrations  WorkspaceIntegration[]
  memberStarBudgets      MemberStarBudget[]
  nboxFolders            NBoxFolder[]
  nboxItems              NBoxItem[]
  nasaPlanners           NasaPlanner[]
  orgPermissions         OrgPermission[]
  activityLogs           OrgActivityLog[]
  systemActivityLogs     SystemActivityLog[]
  userPresences          UserPresence[]
  userSessionRollups     UserSessionRollup[]
  publicPageViews        PublicPageView[]
  savedInsightReports    SavedInsightReport[]
  savedReportCompares    SavedReportCompare[]
  insightLayout          OrganizationInsightLayout?
  workspaces             Workspace[]
  form                   Form[]
  workspaceFolders       WorkspaceFolder[]
  sentShares             ActionShare[]              @relation("SentShares")
  receivedShares         ActionShare[]              @relation("ReceivedShares")
  starRules              StarRule[]
  spacePoints            UserSpacePoint[]
  spacePointTransactions SpacePointTransaction[]
  spacePointPrizes       SpacePointRankingPrize[]

  // NASA Payment
  paymentBankAccounts PaymentBankAccount[]
  paymentCategories   PaymentCategory[]
  paymentCostCenters  PaymentCostCenter[]
  paymentContacts     PaymentContact[]
  paymentEntries      PaymentEntry[]
  paymentAccess       PaymentAccess[]

  // NASA Campaign Planner
  nasaCampaignPlanners NasaCampaignPlanner[]

  // Projetos / Clientes
  orgProjects OrgProject[]

  // Client Onboarding
  clientOnboardingProcesses ClientOnboardingProcess[]

  // Linnker
  linnkerPages LinnkerPage[]

  // NASA Pages
  nasaPages NasaPage[]

  // Space Station
  spaceStation SpaceStation?

  // NASA Planner 2.0: templates de post brandeáveis por-org
  nasaPlannerPostTemplates NasaPlannerPostTemplate[]

  // Alerts (regras configuráveis de notificação)
  alertRules AlertRule[]

  // Marca / Brand
  brandSlogan         String? @map("brand_slogan")
  brandWebsite        String? @map("brand_website")
  brandIcp            String? @map("brand_icp")
  brandPositioning    String? @map("brand_positioning")
  brandVoiceTone      String? @map("brand_voice_tone")
  brandVisual         Json    @default("{}") @map("brand_visual")
  brandAiInstructions String? @map("brand_ai_instructions")
  brandSwot           Json    @default("{}") @map("brand_swot")

  // ── STARS grace period (declarado também aqui pra não dropar) ──
  // Esses 3 campos pertencem oficialmente à STARS PR #68 (em andamento).
  // Replicados nesta branch APENAS pra não ser deletados durante o
  // `migrate dev` (o diff prisma compara DB ↔ schema e droparia o que
  // está só no DB). Quando PR #68 mergear, é apenas resolver conflito
  // de schema.prisma (escolher "both") — semanticamente idêntico.
  starsGraceStartedAt DateTime? @map("stars_grace_started_at")
  starsSuspendedAt    DateTime? @map("stars_suspended_at")
  starsLastAlertAt    DateTime? @map("stars_last_alert_at")

  // ── Brand Kit consolidado (NASA Planner 2.0) ──
  // Populado pela extração automática via Claude Vision (extract-from-logo)
  // ou editado manualmente em /settings/brand. Esses fields são INJETADOS
  // automaticamente nos prompts de IA via `buildBrandedContext(orgId)`
  // (src/features/nasa-planner/lib/brand-context.ts) — garantindo
  // consistência visual em TODA geração (imagem, vídeo, texto).
  brandPaletteHex   Json?     @map("brand_palette_hex")    // ["#7C3AED", "#1447E6", ...]
  brandFontHeading  String?   @map("brand_font_heading")    // "Inter", "Manrope"
  brandFontBody     String?   @map("brand_font_body")
  brandLogoUrl      String?   @map("brand_logo_url")        // R2 key (não URL completa)
  brandLogoVariants Json?     @map("brand_logo_variants")   // {dark, light, monochrome}
  brandExtractedAt  DateTime? @map("brand_extracted_at")    // quando IA extraiu auto

  // ── Localização (para diretório Empresas no mapa) ──
  addressLine String?   @map("address_line")
  city        String?
  state       String?
  postalCode  String?   @map("postal_code")
  country     String?   @default("BR")
  latitude    Float?
  longitude   Float?
  geocodedAt  DateTime? @map("geocoded_at")

  companyType                 String?               @map("company_type") // slug ex: "agencia-publicidade" — vide src/features/company/constants.ts
  companySegment              String?               @map("company_segment") // texto livre opcional (sub-nicho)
  cnpj                        String?
  contactEmail                String?               @map("contact_email")
  contactPhone                String?               @map("contact_phone")
  bio                         String?
  bannerUrl                   String?               @map("banner_url")
  website                     String?
  isSpacehomePublic           Boolean               @default(false) @map("is_spacehome_public")
  spacehomeTemplate           String?               @default("default") @map("spacehome_template")
  nasaPageId                  String?               @unique @map("nasa_page_id")
  nasaPage                    NasaPage?             @relation("OrgSpacehome", fields: [nasaPageId], references: [id], onDelete: SetNull)
  orgRoles                    OrgRole[]
  orgFollows                  OrgFollow[]
  companyReviews              CompanyReview[]
  companyPosts                CompanyPost[]
  spacehomeAuditLogs          SpacehomeAuditLog[]
  nasaRouteCoursesCreated     NasaRouteCourse[]     @relation("NasaRouteCreatorOrg")
  nasaRouteEnrollmentsAsBuyer NasaRouteEnrollment[] @relation("NasaRouteBuyerOrg")
  nasaRouteFreeAccess         NasaRouteFreeAccess[] @relation("NasaRouteFreeAccessOrg")
  nasaRouteVideoUploads       NasaRouteVideoUpload[]

  // ── NASA Partner ──
  partnerReferral        PartnerReferral?
  partnerCommissions     PartnerCommission[]
  partnerLifetimeGranted Boolean             @default(false) @map("partner_lifetime_granted")

  // ── Meta Ads ──
  metaAdsKpiSnapshots MetaAdsKpiSnapshot[]
  metaAdCampaigns     MetaAdCampaign[]
  metaAdSets          MetaAdSet[]
  metaAds             MetaAd[]

  memberMetaAccountAccess MemberMetaAccountAccess[]

  // Meta Ads MCP — autorização e pending actions
  metaMcpAuthorizations MetaMcpAuthorization[]
  metaAdsPendingActions MetaAdsPendingAction[]

  // ── ASTRO (Agentes IA) ──
  aiAgentConfigs AiAgentConfig[]
  aiSessions     AiSession[]
  aiKnowledge    AiKnowledge[]

  @@unique([slug])
  @@map("organization")
}

model Member {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  role           String
  cargo          String?      @map("cargo")
  createdAt      DateTime

  @@unique([userId, organizationId])
  @@index([organizationId])
  @@index([userId])
  @@map("member")
}

model Invitation {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  email          String
  role           String?
  status         String
  expiresAt      DateTime
  inviterId      String
  user           User         @relation(fields: [inviterId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([organizationId])
  @@index([email])
  @@map("invitation")
}

model OrganizationInviteLink {
  id             String    @id @default(cuid())
  organizationId String
  token          String    @unique
  role           String    @default("member")
  expiresAt      DateTime
  createdById    String
  revokedAt      DateTime?
  usesCount      Int       @default(0)
  starsOnJoin    Int       @default(0)
  createdAt      DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    User         @relation("InviteLinksCreated", fields: [createdById], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([token])
  @@map("organization_invite_link")
}

// ─────────────────────────────────────────────
// TRACKING
// ─────────────────────────────────────────────

model Tracking {
  id                        String    @id @default(cuid())
  name                      String
  description               String?
  organizationId            String    @map("organization_id")
  orgProjectId              String?   @map("org_project_id")
  isArchived                Boolean   @default(false) @map("is_archived")
  archivedAt                DateTime? @map("archived_at")
  globalAiActive            Boolean   @default(false) @map("global_ai_active")
  isTemplate                Boolean   @default(false) @map("is_template")
  templateMarkedByModerator Boolean   @default(false) @map("template_marked_by_moderator")
  // Aparência do card no dashboard de Tracking. `cardBorderColor` é uma
  // cor hex/rgb/hsl ou null (sem cor); `cardBackgroundImage` é a chave S3
  // de uma imagem que vira fundo desfocado do card.
  // `cardBackgroundBlur` é o raio do filter blur em px (0-30, default 8).
  // `cardBackgroundOpacity` é a opacidade da imagem em % (0-100, default 25).
  cardBorderColor           String?   @map("card_border_color")
  cardBackgroundImage       String?   @map("card_background_image")
  cardBackgroundBlur        Int       @default(8) @map("card_background_blur")
  cardBackgroundOpacity     Int       @default(25) @map("card_background_opacity")
  // Aparência do Kanban (view de pipeline). Cor de fundo + borda dos
  // cards de lead, da coluna de status e do canvas do tracking. Para o
  // canvas suporta imagem com blur + opacity (mesclada com a cor base).
  kanbanCardBackgroundColor    String? @map("kanban_card_background_color")
  kanbanCardBorderColor        String? @map("kanban_card_border_color")
  // Transparência do fundo do card (0-100). Default 100 = opaco. Só
  // aplica quando `kanbanCardBackgroundColor` está definido.
  kanbanCardBackgroundOpacity  Int     @default(100) @map("kanban_card_background_opacity")
  kanbanColumnBackgroundColor  String? @map("kanban_column_background_color")
  kanbanColumnBorderColor      String? @map("kanban_column_border_color")
  // Transparência do fundo da coluna (0-100). Default 100 = opaco.
  kanbanColumnBackgroundOpacity Int    @default(100) @map("kanban_column_background_opacity")
  kanbanBackgroundColor        String? @map("kanban_background_color")
  kanbanBackgroundImage        String? @map("kanban_background_image")
  // Raio do blur da imagem de fundo (0-30px). Default 0 = sem desfoque.
  kanbanBackgroundBlur         Int     @default(0) @map("kanban_background_blur")
  // Opacidade da imagem em % (0-100). Default 50 = 50% mesclado com a cor.
  kanbanBackgroundOpacity      Int     @default(50) @map("kanban_background_opacity")
  createdAt                 DateTime  @default(now()) @map("created_at")
  updatedAt                 DateTime  @updatedAt @map("updated_at")

  // Relacionamentos
  organization        Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  orgProject          OrgProject?           @relation(fields: [orgProjectId], references: [id], onDelete: SetNull)
  participants        TrackingParticipant[]
  status              Status[]
  leads               Lead[]
  tags                Tag[]
  winLossReasons      WinLossReason[]
  actions             Action[]
  workflows           Workflow[]
  forms               FormSettings[]
  whatsappInstance    WhatsAppInstance?
  conversations       Conversation[]
  agendas             Agenda[]
  appointments        Appointment[]
  aiSettings          AiSettings?
  aiButtonPresets     AiButtonPreset[]
  trackingConsultants TrackingConsultant[]
  workspaces          Workspace[]
  scripts             Script[]
  reminders           Reminder[]
  paymentEntries      PaymentEntry[]
  cardConfig          TrackingCardConfig?
  idleAutomation      TrackingIdleAutomation?

  @@map("tracking")
}

enum IdleAutomationMessageMode {
  NONE
  FIXED
  AI_REOPEN

  @@map("idle_automation_message_mode")
}

model TrackingIdleAutomation {
  id         String   @id @default(cuid())
  trackingId String   @unique @map("tracking_id")
  tracking   Tracking @relation(fields: [trackingId], references: [id], onDelete: Cascade)

  // Cenário 1: lead criado e ninguém respondeu ainda
  noFirstRespActive       Boolean                   @default(false) @map("no_first_resp_active")
  noFirstRespMinutes      Int                       @default(60)    @map("no_first_resp_minutes")
  noFirstRespEnableAi     Boolean                   @default(false) @map("no_first_resp_enable_ai")
  noFirstRespMessageMode  IdleAutomationMessageMode @default(NONE)  @map("no_first_resp_message_mode")
  noFirstRespMessage      String?                                    @map("no_first_resp_message")
  noFirstRespNotifyResp   Boolean                   @default(false) @map("no_first_resp_notify_resp")
  noFirstRespRespTemplate String?                                    @map("no_first_resp_resp_template")

  // Cenário 2: lead em conversa, sem nova outbound do atendente
  inConvActive       Boolean                   @default(false) @map("in_conv_active")
  inConvMinutes      Int                       @default(120)   @map("in_conv_minutes")
  inConvEnableAi     Boolean                   @default(false) @map("in_conv_enable_ai")
  inConvMessageMode  IdleAutomationMessageMode @default(NONE)  @map("in_conv_message_mode")
  inConvMessage      String?                                    @map("in_conv_message")
  inConvNotifyResp   Boolean                   @default(false) @map("in_conv_notify_resp")
  inConvRespTemplate String?                                    @map("in_conv_resp_template")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("tracking_idle_automation")
}

model TrackingCardConfig {
  id         String   @id @default(cuid())
  trackingId String   @unique @map("tracking_id")
  fields     Json     @default("[]")
  showSlaTimer Boolean @default(true) @map("show_sla_timer")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  tracking Tracking @relation(fields: [trackingId], references: [id], onDelete: Cascade)

  @@map("tracking_card_config")
}

model AiSettings {
  id             String  @id @default(cuid())
  prompt         String
  assistantName  String? @map("assistant_name")
  finishSentence String? @map("finish_sentence")
  isAudioEnabled Boolean @default(false) @map("is_audio_enabled")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  trackingId String   @unique
