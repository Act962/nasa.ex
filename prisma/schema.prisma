/// Timeline granular de eventos por lead — alimenta a tab "Jornada" do lead e o
/// painel de Insights. Reusa onde possível, mas o `LeadHistory` está limitado pelo
/// enum `LeadAction` (4 valores) e o `SystemActivityLog` é por org/user, não por lead.
model LeadJourneyEvent {
