  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  courses NasaRouteCourse[]

  @@map("nasa_route_category")
}

model NasaRouteCourse {
  id                 String    @id @default(cuid())
  slug               String
  title              String
  subtitle           String?
  description        String?
  coverUrl           String?   @map("cover_url")
  trailerUrl         String?   @map("trailer_url")
  level              String    @default("beginner")
  durationMin        Int?      @map("duration_min")
  format             String    @default("course") // "course" | "training" | "mentoring" | "ebook" | "event" | "community" | "subscription"
  creatorOrgId       String    @map("creator_org_id")
  creatorUserId      String    @map("creator_user_id")
  categoryId         String?   @map("category_id")
  priceStars         Int       @default(0) @map("price_stars")
  // Preço em centavos BRL — fonte de verdade para checkout Stripe.
  // priceStars permanece por compatibilidade mas não é mais usado em compras.
  priceBrlCents      Int       @default(0) @map("price_brl_cents")
  // Flag explícita de curso gratuito. Quando true, força priceBrlCents=0
  // e o fluxo de matrícula bypassa o Stripe.
  isFree             Boolean   @default(false) @map("is_free")
  isPublished        Boolean   @default(false) @map("is_published")
  publishedAt        DateTime? @map("published_at")
  studentsCount      Int       @default(0) @map("students_count")
  rewardSpOnComplete Int       @default(0) @map("reward_sp_on_complete")

  // Soft-delete / arquivamento. Cursos com `isArchived=true` somem das
  // listagens públicas mas continuam no banco (alunos matriculados ainda
  // têm acesso ao conteúdo, admin vê em aba "Arquivados"). O cron
  // `nasa-route-archive-past-events` marca eventos com `endsAt < now()`.
  isArchived Boolean   @default(false) @map("is_archived")
  archivedAt DateTime? @map("archived_at")

  // Datas de início/fim — UNIFICADAS pra todos os formatos. Substituem
  // `eventStartsAt`/`eventEndsAt` (que ficam preservados pra compat;
  // dados novos populam `startsAt`/`endsAt`). Treinamento, mentoria,
  // evento, ebook, etc. — qualquer formato pode ter janela temporal.
  startsAt DateTime? @map("starts_at")
  endsAt   DateTime? @map("ends_at")

  // Funil de vendas — quando alguém compra este curso, o sistema
  // cria/move um lead nesse tracking + status. Permite o criador puxar
  // os compradores pro CRM e dar follow-up no atendimento.
  // Ambos opcionais — sem isso, a compra não cria lead automático.
  purchaseTrackingId String? @map("purchase_tracking_id")
  purchaseStatusId   String? @map("purchase_status_id")

  // ── Integrações de marketing ───────────────────────────────
  // URL pra redirecionar o comprador após o checkout (ex: página
  // de obrigado/agradecimento do criador). Vazio = sem redirect.
  redirectUrl  String? @map("redirect_url")
  // IDs externos pra injetar scripts de tracking na página pública
  // do curso. Exemplos: "123456789" (Pixel), "GTM-XXXXXXX" (GTM).
  pixelId      String? @map("pixel_id")
  gtmId        String? @map("gtm_id")

  // eBook (format = "ebook")
  ebookFileKey   String? @map("ebook_file_key")
  ebookFileName  String? @map("ebook_file_name")
  ebookFileSize  Int?    @map("ebook_file_size")
  ebookMimeType  String? @map("ebook_mime_type")
  ebookPageCount Int?    @map("ebook_page_count")

  // Evento Online (format = "event")
  eventStartsAt     DateTime? @map("event_starts_at")
  eventEndsAt       DateTime? @map("event_ends_at")
  eventStreamUrl    String?   @map("event_stream_url")
  eventTimezone     String?   @map("event_timezone")
  eventLocationNote String?   @map("event_location_note")

  // Comunidade (format = "community")
  communityType      String? @map("community_type") // "whatsapp" | "telegram" | "discord" | "other"
  communityInviteUrl String? @map("community_invite_url")
  communityRules     String? @map("community_rules")

  // Assinatura (format = "subscription") — preço em NasaRoutePlan.priceStars; aqui só a periodicidade
  subscriptionPeriod String? @map("subscription_period") // "monthly" (V1) | "yearly" (V2)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  creatorOrg       Organization            @relation("NasaRouteCreatorOrg", fields: [creatorOrgId], references: [id], onDelete: Cascade)
  creatorUser      User                    @relation("NasaRouteCreatorUser", fields: [creatorUserId], references: [id], onDelete: Restrict)
  category         NasaRouteCategory?      @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  modules          NasaRouteModule[]
  lessons          NasaRouteLesson[]
  enrollments      NasaRouteEnrollment[]
  progress         NasaRouteProgress[]
  freeAccess       NasaRouteFreeAccess[]
  plans            NasaRoutePlan[]
  certificates     NasaRouteCertificate[]
  pendingPurchases PendingCoursePurchase[]
  videoUploads     NasaRouteVideoUpload[]

  @@unique([creatorOrgId, slug])
  @@index([creatorOrgId])
  @@index([categoryId])
  @@index([isPublished, publishedAt])
  @@index([isArchived])
  @@index([endsAt])
  @@map("nasa_route_course")
}

model NasaRouteModule {
  id        String   @id @default(cuid())
  courseId  String   @map("course_id")
  order     Int      @default(0)
  title     String
  summary   String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  course  NasaRouteCourse   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons NasaRouteLesson[]

  @@index([courseId, order])
  @@map("nasa_route_module")
}

model NasaRouteLesson {
  id            String   @id @default(cuid())
  courseId      String   @map("course_id")
  moduleId      String?  @map("module_id")
  order         Int      @default(0)
  title         String
  summary       String?
  contentMd     String?  @map("content_md")
  videoUrl      String?  @map("video_url")
  videoProvider String?  @map("video_provider") // "youtube" | "vimeo"
  videoId       String?  @map("video_id")
  // Vídeo hospedado no R2 NASA Route (bucket dedicado). Mutuamente exclusivo
  // com `videoUrl` — quando upload completa, videoUrl é zerado e vice-versa.
  videoFileKey  String?  @map("video_file_key")
  videoFileSize BigInt?  @map("video_file_size")
  // Thumbnail customizada da aula — chave S3/R2 (bucket principal, não
  // o `nasa-route-videos`). Opcional: se null, a UI usa um placeholder
  // ou o primeiro frame do vídeo.
  thumbnailKey  String?  @map("thumbnail_key")
  durationMin   Int?     @map("duration_min")
  isFreePreview Boolean  @default(false) @map("is_free_preview")
  awardSp       Int      @default(10) @map("award_sp")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  course       NasaRouteCourse        @relation(fields: [courseId], references: [id], onDelete: Cascade)
  module       NasaRouteModule?       @relation(fields: [moduleId], references: [id], onDelete: SetNull)
  planLessons  NasaRoutePlanLesson[]
  videoUploads NasaRouteVideoUpload[]
  attachments  NasaRouteLessonAttachment[]

  @@index([courseId, order])
  @@map("nasa_route_lesson")
}

/**
 * Anexos da aula (PDF, imagens, docs, planilhas) — exibidos pro aluno
 * matriculado dentro do player da aula, com botões de visualizar/baixar.
 * Espelho de `NasaRoutePlanAttachment` mas vinculado direto à `Lesson`
 * pra suportar "Conteúdo complementar" sem precisar passar pelo plano.
 */
model NasaRouteLessonAttachment {
  id          String   @id @default(cuid())
  lessonId    String   @map("lesson_id")
  // "file" (PDF/doc/etc) | "image" | "link" (URL externa sem upload)
  kind        String
  title       String
  // Pra `kind=link`: URL externa. Pra outros: opcional (fallback).
  url         String?
  // Chave S3/R2 do arquivo (bucket principal). Obrigatória pra kind != "link".
  fileKey     String?  @map("file_key")
  fileName    String?  @map("file_name")
  fileSize    Int?     @map("file_size")
  mimeType    String?  @map("mime_type")
  description String?
  order       Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  lesson NasaRouteLesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@index([lessonId, order])
  @@map("nasa_route_lesson_attachment")
}

// Tracking de upload multipart de vídeo (bucket R2 dedicado nasa-route-videos).
// Vida útil: criado em `creatorStartVideoUpload` (status=uploading), atualizado
// em `creatorCompleteVideoUpload`/`creatorAbortVideoUpload`, ou expirado pelo
// cron Inngest se ficar >7d sem progredir. STARs são cobradas upfront e
// registradas em `costStars` pra auditoria.
model NasaRouteVideoUpload {
  id                String @id @default(cuid())
  courseId          String @map("course_id")
  lessonId          String @map("lesson_id")
  userId            String @map("user_id") // criador que iniciou
  organizationId    String @map("organization_id") // org que pagou STARs

  fileKey           String @map("file_key") // key final no R2
  multipartUploadId String @map("multipart_upload_id") // UploadId do R2
  filename          String
  mimeType          String @map("mime_type")
  sizeBytes         BigInt @map("size_bytes")
  totalParts        Int    @map("total_parts")

  costStars         Int    @map("cost_stars") // cobrado upfront via debitStars
  status            String @default("uploading") // "uploading" | "completed" | "aborted" | "failed" | "expired"

  startedAt   DateTime  @default(now()) @map("started_at")
  completedAt DateTime? @map("completed_at")

  course       NasaRouteCourse @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lesson       NasaRouteLesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([status, startedAt]) // pro cron de cleanup
  @@index([lessonId])
  @@index([organizationId])
  @@map("nasa_route_video_upload")
}

model NasaRouteEnrollment {
  id          String    @id @default(cuid())
  userId      String    @map("user_id")
  courseId    String    @map("course_id")
  planId      String?   @map("plan_id")
  buyerOrgId  String?   @map("buyer_org_id")
  paidStars   Int       @default(0) @map("paid_stars")
  // Pagamento via Stripe (BRL). Snapshot do valor pago em centavos +
  // referências à sessão/payment intent para reconciliação e refund.
  paidBrlCents            Int?    @map("paid_brl_cents")
  stripeCheckoutSessionId String? @unique @map("stripe_checkout_session_id")
  stripePaymentIntentId   String? @map("stripe_payment_intent_id")
  source      String    @default("purchase") // "purchase" | "free_access" | "gift" | "stripe_purchase"
  paymentRef  String?   @map("payment_ref")
  status      String    @default("active") // "active" | "refunded"
  enrolledAt  DateTime  @default(now()) @map("enrolled_at")
  completedAt DateTime? @map("completed_at")

  user         User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course       NasaRouteCourse        @relation(fields: [courseId], references: [id], onDelete: Cascade)
  plan         NasaRoutePlan?         @relation(fields: [planId], references: [id], onDelete: SetNull)
  buyerOrg     Organization?          @relation("NasaRouteBuyerOrg", fields: [buyerOrgId], references: [id], onDelete: SetNull)
  certificate  NasaRouteCertificate?
  subscription NasaRouteSubscription?

  @@unique([userId, courseId])
  @@index([userId])
  @@index([courseId])
  @@index([planId])
  @@map("nasa_route_enrollment")
}

model NasaRouteSubscription {
  id                 String    @id @default(cuid())
  enrollmentId       String    @unique @map("enrollment_id")
  status             String    @default("active") // "active" | "past_due" | "cancelled" | "expired"
  startedAt          DateTime  @default(now()) @map("started_at")
  currentPeriodStart DateTime  @map("current_period_start")
  currentPeriodEnd   DateTime  @map("current_period_end")
  nextChargeAt       DateTime  @map("next_charge_at")
  lastChargedAt      DateTime? @map("last_charged_at")
  failedChargeCount  Int       @default(0) @map("failed_charge_count")
  cancelledAt        DateTime? @map("cancelled_at")
  cancelReason       String?   @map("cancel_reason")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  enrollment NasaRouteEnrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)

  @@index([nextChargeAt, status])
  @@map("nasa_route_subscription")
}

model NasaRouteProgress {
  id                 String    @id @default(cuid())
  userId             String    @map("user_id")
  courseId           String    @map("course_id")
  completedLessonIds String[]  @map("completed_lesson_ids")
  lastLessonId       String?   @map("last_lesson_id")
  startedAt          DateTime  @default(now()) @map("started_at")
  completedAt        DateTime? @map("completed_at")

  user   User            @relation(fields: [userId], references: [id], onDelete: Cascade)
