// ─────────────────────────────────────────────
// NASA Route — Checkout público (compra sem conta)
// ─────────────────────────────────────────────

enum PendingCoursePurchaseStatus {
  PENDING
  PAID
  REDEEMED
  EXPIRED
  REFUNDED
  CANCELLED
}

// Compra de curso iniciada por usuário sem conta. Após pagamento confirmado
// pelo Stripe, gera signupToken enviado por e-mail; o resgate cria User+Org
// e matricula o aluno no curso.
model PendingCoursePurchase {
  id                    String                      @id @default(cuid())
  email                 String
  // Quando o checkout foi iniciado por um usuário já autenticado,
  // gravamos o userId para finalizar a matrícula direto no webhook
  // (sem passar pelo signup token). null = fluxo público anônimo.
  userId                String?                     @map("user_id")
  // Discriminador do fluxo: "public" (anônimo, gera signupToken) ou
  // "authenticated" (já tem conta, webhook finaliza enrollment direto).
  flow                  String                      @default("public")
  courseId              String                      @map("course_id")
  planId                String?                     @map("plan_id")
  priceStars            Int                         @map("price_stars")
  amountBrlCents        Int                         @map("amount_brl_cents")
  starPriceBrlSnapshot  Decimal                     @map("star_price_brl_snapshot") @db.Decimal(10, 4)
  stripeSessionId       String?                     @map("stripe_session_id")
  stripePaymentIntentId String?                     @map("stripe_payment_intent_id")
  signupToken           String?                     @unique @map("signup_token")
  tokenExpiresAt        DateTime?                   @map("token_expires_at")
  status                PendingCoursePurchaseStatus @default(PENDING)
  createdAt             DateTime                    @default(now()) @map("created_at")
  paidAt                DateTime?                   @map("paid_at")
  redeemedAt            DateTime?                   @map("redeemed_at")
  redeemedByUserId      String?                     @map("redeemed_by_user_id")
  redeemedEnrollmentId  String?                     @map("redeemed_enrollment_id")

  course         NasaRouteCourse @relation(fields: [courseId], references: [id], onDelete: Cascade)
  plan           NasaRoutePlan?  @relation(fields: [planId], references: [id], onDelete: SetNull)
  redeemedByUser User?           @relation("PendingCoursePurchaseRedeemer", fields: [redeemedByUserId], references: [id], onDelete: SetNull)
  user           User?           @relation("PendingCoursePurchaseUser", fields: [userId], references: [id], onDelete: SetNull)

  @@index([email])
  @@index([userId])
  @@index([status])
  @@index([stripeSessionId])
  @@map("pending_course_purchase")
}

// Configurações globais de pricing do NASA Route. Singleton (id="singleton").
model RouterPaymentSettings {
  id           String   @id
  starPriceBrl Decimal  @default(0.15) @map("star_price_brl") @db.Decimal(10, 4)
  updatedAt    DateTime @updatedAt @map("updated_at")
  updatedById  String?  @map("updated_by_id")

  updatedBy User? @relation("RouterPaymentSettingsUpdater", fields: [updatedById], references: [id], onDelete: SetNull)

  @@map("router_payment_settings")
}

// ─────────────────────────────────────────────
// NASA PARTNER — Programa de Parceiros
// ─────────────────────────────────────────────

enum PartnerTier {
  SUITE
  EARTH
  GALAXY
  CONSTELLATION
  INFINITY
}

enum PartnerStatus {
  ELIGIBLE // ainda <10 orgs ativas, link funciona mas sem painel
  ACTIVE // habilitado, painel /partner liberado
  SUSPENDED // pausado pelo admin
}

enum PartnerCommissionStatus {
  PENDING // ciclo aberto
  READY // ciclo fechou, payout criado, aguardando repasse
  PAID // repassado
  CANCELLED // estornado
}

enum PartnerPayoutStatus {
  SCHEDULED // ciclo fechado, aguardando data de repasse
  ADVANCED // antecipado pelo parceiro
  PAID // pago
  FAILED // falha no repasse
}

enum PartnerReferralActivity {
  ACTIVE
  AT_RISK
  INACTIVE
}

model PartnerReferralLink {
  id        String   @id @default(cuid())
  userId    String   @unique @map("user_id")
  code      String   @unique
  visits    Int      @default(0)
  signups   Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")

  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  visitsLog PartnerLinkVisit[]
  referrals PartnerReferral[]

  @@index([code])
  @@map("partner_referral_link")
}

model PartnerLinkVisit {
  id        String   @id @default(cuid())
  linkId    String   @map("link_id")
  ip        String?
  userAgent String?  @map("user_agent")
  visitedAt DateTime @default(now()) @map("visited_at")

  link PartnerReferralLink @relation(fields: [linkId], references: [id], onDelete: Cascade)

  @@index([linkId, visitedAt])
  @@map("partner_link_visit")
}

model PartnerReferral {
  id                       String                  @id @default(cuid())
  linkId                   String?                 @map("link_id")
  partnerUserId            String                  @map("partner_user_id")
  referredOrganizationId   String                  @unique @map("referred_organization_id")
  signedUpAt               DateTime                @default(now()) @map("signed_up_at")
  source                   String                  @default("link") // "link" | "admin_manual"
  attachedByAdminId        String?                 @map("attached_by_admin_id")
  attachedReason           String?                 @map("attached_reason")
  activityStatus           PartnerReferralActivity @default(ACTIVE) @map("activity_status")
  lastQualifyingActivityAt DateTime?               @map("last_qualifying_activity_at")
  lastQualifyingType       String?                 @map("last_qualifying_type") // "purchase" | "consumption"
  totalStarsConsumed       Int                     @default(0) @map("total_stars_consumed")
  totalPurchasedBrl        Decimal                 @default(0) @map("total_purchased_brl") @db.Decimal(10, 2)
  activityRecalcedAt       DateTime?               @map("activity_recalced_at")

  link                 PartnerReferralLink? @relation(fields: [linkId], references: [id], onDelete: SetNull)
  partnerUser          User                 @relation("PartnerReferralsAsPartner", fields: [partnerUserId], references: [id], onDelete: Cascade)
  referredOrganization Organization         @relation(fields: [referredOrganizationId], references: [id], onDelete: Cascade)
  attachedByAdmin      User?                @relation("PartnerReferralsAttachedByAdmin", fields: [attachedByAdminId], references: [id], onDelete: SetNull)

  @@index([partnerUserId, activityStatus])
  @@index([source])
  @@map("partner_referral")
}

model Partner {
  id                      String        @id @default(cuid())
  userId                  String        @unique @map("user_id")
  status                  PartnerStatus @default(ELIGIBLE)
  tier                    PartnerTier?
  tierAchievedAt          DateTime?     @map("tier_achieved_at")
  activatedAt             DateTime?     @map("activated_at")
  totalEarnedBrl          Decimal       @default(0) @map("total_earned_brl") @db.Decimal(10, 2)
  totalPaidBrl            Decimal       @default(0) @map("total_paid_brl") @db.Decimal(10, 2)
  totalSavingsBrl         Decimal       @default(0) @map("total_savings_brl") @db.Decimal(10, 2)
  totalReferralRevenueBrl Decimal       @default(0) @map("total_referral_revenue_brl") @db.Decimal(10, 2)
  manualTierOverride      Boolean       @default(false) @map("manual_tier_override")
  promotedByAdminId       String?       @map("promoted_by_admin_id")
  gracePeriodEndsAt       DateTime?     @map("grace_period_ends_at")
  gracePeriodFromTier     PartnerTier?  @map("grace_period_from_tier")
  gracePeriodToTier       PartnerTier?  @map("grace_period_to_tier")
  lastTierEvalAt          DateTime?     @map("last_tier_eval_at")
  acceptedTermsVersionId  String?       @map("accepted_terms_version_id")
  acceptedTermsAt         DateTime?     @map("accepted_terms_at")
  notes                   String?
  createdAt               DateTime      @default(now()) @map("created_at")
  updatedAt               DateTime      @updatedAt @map("updated_at")

  user             User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  commissions      PartnerCommission[]
  payouts          PartnerPayout[]
  starPurchases    PartnerStarPurchase[]
  termsAcceptances PartnerTermsAcceptance[]
  tierHistory      PartnerTierHistory[]

  @@index([status, tier])
  @@map("partner")
}

model PartnerCommission {
  id                   String                  @id @default(cuid())
  partnerId            String                  @map("partner_id")
  payoutId             String?                 @map("payout_id")
  starsPaymentId       String                  @unique @map("stars_payment_id")
  organizationId       String                  @map("organization_id")
  tierAtMoment         PartnerTier             @map("tier_at_moment")
  ratePercent          Decimal                 @map("rate_percent") @db.Decimal(5, 2)
  packageIdSnapshot    String                  @map("package_id_snapshot")
  packageLabelSnapshot String                  @map("package_label_snapshot")
  starsAmountSnapshot  Int                     @map("stars_amount_snapshot")
  unitPriceBrlSnapshot Decimal                 @map("unit_price_brl_snapshot") @db.Decimal(10, 4)
  basePaymentBrl       Decimal                 @map("base_payment_brl") @db.Decimal(10, 2)
  commissionBrl        Decimal                 @map("commission_brl") @db.Decimal(10, 2)
  status               PartnerCommissionStatus @default(PENDING)
  cycleYearMonth       String                  @map("cycle_year_month") // "2026-04"
  createdAt            DateTime                @default(now()) @map("created_at")

  partner      Partner        @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  payout       PartnerPayout? @relation(fields: [payoutId], references: [id], onDelete: SetNull)
  starsPayment StarsPayment   @relation(fields: [starsPaymentId], references: [id])
  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([partnerId, status])
  @@index([cycleYearMonth])
  @@map("partner_commission")
}

model PartnerStarPurchase {
  id                  String      @id @default(cuid())
  partnerId           String      @map("partner_id")
  starsPaymentId      String      @unique @map("stars_payment_id")
  tierAtMoment        PartnerTier @map("tier_at_moment")
  discountRatePercent Decimal     @map("discount_rate_percent") @db.Decimal(5, 2)
  starsAmountSnapshot Int         @map("stars_amount_snapshot")
  originalPriceBrl    Decimal     @map("original_price_brl") @db.Decimal(10, 2)
  paidPriceBrl        Decimal     @map("paid_price_brl") @db.Decimal(10, 2)
  savingsBrl          Decimal     @map("savings_brl") @db.Decimal(10, 2)
  createdAt           DateTime    @default(now()) @map("created_at")

  partner      Partner      @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  starsPayment StarsPayment @relation(fields: [starsPaymentId], references: [id])

  @@index([partnerId, createdAt])
  @@map("partner_star_purchase")
}

model PartnerPayout {
  id             String              @id @default(cuid())
  partnerId      String              @map("partner_id")
  cycleYearMonth String              @map("cycle_year_month")
  cycleStart     DateTime            @map("cycle_start")
  cycleEnd       DateTime            @map("cycle_end")
  scheduledFor   DateTime            @map("scheduled_for")
  grossBrl       Decimal             @map("gross_brl") @db.Decimal(10, 2)
  advanceFeeBrl  Decimal             @default(0) @map("advance_fee_brl") @db.Decimal(10, 2)
  netBrl         Decimal             @map("net_brl") @db.Decimal(10, 2)
  status         PartnerPayoutStatus @default(SCHEDULED)
  paidAt         DateTime?           @map("paid_at")
  paidByAdminId  String?             @map("paid_by_admin_id")
  proofUrl       String?             @map("proof_url")
  notes          String?
  createdAt      DateTime            @default(now()) @map("created_at")

  partner     Partner             @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  paidByAdmin User?               @relation("PartnerPayoutPaidBy", fields: [paidByAdminId], references: [id], onDelete: SetNull)
  commissions PartnerCommission[]

  @@unique([partnerId, cycleYearMonth])
  @@index([status, scheduledFor])
  @@map("partner_payout")
}

model PartnerTierHistory {
  id              String       @id @default(cuid())
  partnerId       String       @map("partner_id")
  fromTier        PartnerTier? @map("from_tier")
  toTier          PartnerTier? @map("to_tier")
  reason          String // "auto_upgrade" | "auto_downgrade" | "admin_manual" | "grace_expired" | "first_activation"
  activeReferrals Int          @map("active_referrals")
  triggeredById   String?      @map("triggered_by_id")
  createdAt       DateTime     @default(now()) @map("created_at")

  partner     Partner @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  triggeredBy User?   @relation("PartnerTierHistoryTrigger", fields: [triggeredById], references: [id], onDelete: SetNull)

  @@index([partnerId, createdAt])
  @@map("partner_tier_history")
}

model PartnerTermsVersion {
  id               String   @id @default(cuid())
  version          String   @unique
  title            String
  spaceHelpTrackId String?  @map("space_help_track_id")
  contentHash      String   @map("content_hash")
  effectiveAt      DateTime @map("effective_at")
  publishedById    String?  @map("published_by_id")
  changeSummary    String?  @map("change_summary")
  isActive         Boolean  @default(false) @map("is_active")
  createdAt        DateTime @default(now()) @map("created_at")

  publishedBy User?                    @relation("PartnerTermsVersionPublisher", fields: [publishedById], references: [id], onDelete: SetNull)
  acceptances PartnerTermsAcceptance[]

  @@index([isActive, effectiveAt])
  @@map("partner_terms_version")
}

model PartnerTermsAcceptance {
  id                String   @id @default(cuid())
  partnerId         String   @map("partner_id")
  termsVersionId    String   @map("terms_version_id")
  acceptedAt        DateTime @default(now()) @map("accepted_at")
  ipAddress         String?  @map("ip_address")
  userAgent         String?  @map("user_agent")
  contentHashAtTime String   @map("content_hash_at_time")

  partner      Partner             @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  termsVersion PartnerTermsVersion @relation(fields: [termsVersionId], references: [id], onDelete: Cascade)

  @@unique([partnerId, termsVersionId])
  @@index([partnerId])
  @@map("partner_terms_acceptance")
}

model PartnerProgramSettings {
  id                          String   @id @default("singleton")
  suiteThreshold              Int      @default(10) @map("suite_threshold")
  earthThreshold              Int      @default(25) @map("earth_threshold")
  galaxyThreshold             Int      @default(50) @map("galaxy_threshold")
  constellationThreshold      Int      @default(100) @map("constellation_threshold")
  infinityThreshold           Int      @default(200) @map("infinity_threshold")
  suiteCommissionRate         Decimal  @default(10) @map("suite_commission_rate") @db.Decimal(5, 2)
  earthCommissionRate         Decimal  @default(15) @map("earth_commission_rate") @db.Decimal(5, 2)
  galaxyCommissionRate        Decimal  @default(20) @map("galaxy_commission_rate") @db.Decimal(5, 2)
  constellationCommissionRate Decimal  @default(30) @map("constellation_commission_rate") @db.Decimal(5, 2)
  infinityCommissionRate      Decimal  @default(40) @map("infinity_commission_rate") @db.Decimal(5, 2)
  suiteDiscountRate           Decimal  @default(10) @map("suite_discount_rate") @db.Decimal(5, 2)
  earthDiscountRate           Decimal  @default(15) @map("earth_discount_rate") @db.Decimal(5, 2)
  galaxyDiscountRate          Decimal  @default(20) @map("galaxy_discount_rate") @db.Decimal(5, 2)
  constellationDiscountRate   Decimal  @default(50) @map("constellation_discount_rate") @db.Decimal(5, 2)
  infinityDiscountRate        Decimal  @default(50) @map("infinity_discount_rate") @db.Decimal(5, 2)
  payoutDayOfMonth            Int      @default(10) @map("payout_day_of_month")
  advanceFeePercent           Decimal  @default(5) @map("advance_fee_percent") @db.Decimal(5, 2)
  advanceMinDaysBefore        Int      @default(3) @map("advance_min_days_before")
  activeOrgWindowDays         Int      @default(90) @map("active_org_window_days")
  activeOrgMinPurchaseBrl     Decimal  @default(0) @map("active_org_min_purchase_brl") @db.Decimal(10, 2)
  activeOrgMinStarsConsumed   Int      @default(1) @map("active_org_min_stars_consumed")
  atRiskWarningDays           Int      @default(14) @map("at_risk_warning_days")
  downgradeGracePeriodDays    Int      @default(30) @map("downgrade_grace_period_days")
  tierRecalcCadenceDays       Int      @default(1) @map("tier_recalc_cadence_days")
  updatedAt                   DateTime @updatedAt @map("updated_at")

  @@map("partner_program_settings")
}

// ─────────────────────────────────────────────
// META ADS — campanhas pagas (Insights + Ads Management)
// ─────────────────────────────────────────────

enum MetaAdEntityStatus {
  ACTIVE
  PAUSED
  DELETED
  ARCHIVED
  PENDING_REVIEW
  DISAPPROVED
  PREAPPROVED
  PENDING_BILLING_INFO
  CAMPAIGN_PAUSED
  ADSET_PAUSED
  IN_PROCESS
  WITH_ISSUES
}

enum MetaAdLevel {
  ACCOUNT
  CAMPAIGN
  ADSET
  AD
}

// Snapshot diário de KPIs Meta Ads (account/campaign/adset/ad).
// Permite histórico/séries temporais e drill-down sem refazer chamadas à API.
model MetaAdsKpiSnapshot {
  id             String      @id @default(cuid())
  organizationId String      @map("organization_id")
  level          MetaAdLevel
  entityId       String      @map("entity_id") // ID Meta da entidade (account/campaign/adset/ad)
  entityName     String?     @map("entity_name")
  date           DateTime    @db.Date
  datePreset     String?     @map("date_preset")

  // Core
  reach       Int     @default(0)
  impressions Int     @default(0)
  frequency   Decimal @default(0) @db.Decimal(10, 4)
  clicks      Int     @default(0)
  ctr         Decimal @default(0) @db.Decimal(10, 4)
  engagement  Int     @default(0)

  // Custos (BRL)
  spend Decimal @default(0) @db.Decimal(14, 2)
  cpm   Decimal @default(0) @db.Decimal(14, 4)
  cpc   Decimal @default(0) @db.Decimal(14, 4)
  cpp   Decimal @default(0) @db.Decimal(14, 4)
  cpl   Decimal @default(0) @db.Decimal(14, 4)
  cpa   Decimal @default(0) @db.Decimal(14, 4)
  cpv   Decimal @default(0) @db.Decimal(14, 4)

  // Conversão
  conversions     Int     @default(0)
  leads           Int     @default(0)
  conversionValue Decimal @default(0) @map("conversion_value") @db.Decimal(14, 2)
  conversionRate  Decimal @default(0) @map("conversion_rate") @db.Decimal(10, 4)
  roas            Decimal @default(0) @db.Decimal(14, 4)
  roi             Decimal @default(0) @db.Decimal(14, 4)

  // Vídeo
  videoPlays        Int     @default(0) @map("video_plays")
  videoP25          Int     @default(0) @map("video_p25")
  videoP50          Int     @default(0) @map("video_p50")
  videoP75          Int     @default(0) @map("video_p75")
  videoP100         Int     @default(0) @map("video_p100")
  videoAvgWatchTime Decimal @default(0) @map("video_avg_watch_time") @db.Decimal(10, 2)

  raw       Json? // payload bruto Meta para debug
  syncedAt  DateTime @default(now()) @map("synced_at")
  createdAt DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, level, entityId, date])
  @@index([organizationId, level, date])
  @@index([organizationId, entityId])
  @@map("meta_ads_kpi_snapshots")
}

// Espelho de campanhas Meta Ads gerenciadas via NASA.
// Quando criada pelo backend NASA → metaCampaignId só é preenchido após sync com Meta.
model MetaAdCampaign {
  id                  String             @id @default(cuid())
  organizationId      String             @map("organization_id")
  metaCampaignId      String?            @unique @map("meta_campaign_id")
  adAccountId         String             @map("ad_account_id")
  name                String
  objective           String?
  status              MetaAdEntityStatus @default(PAUSED)
  effectiveStatus     String?            @map("effective_status")
  specialAdCategories String[]           @default([]) @map("special_ad_categories")
  buyingType          String?            @map("buying_type")
  dailyBudget         Decimal?           @map("daily_budget") @db.Decimal(14, 2)
  lifetimeBudget      Decimal?           @map("lifetime_budget") @db.Decimal(14, 2)
  bidStrategy         String?            @map("bid_strategy")
  startTime           DateTime?          @map("start_time")
  stopTime            DateTime?          @map("stop_time")
  createdByUserId     String?            @map("created_by_user_id")
  lastSyncedAt        DateTime?          @map("last_synced_at")
  raw                 Json?
  createdAt           DateTime           @default(now()) @map("created_at")
  updatedAt           DateTime           @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  adsets       MetaAdSet[]
  ads          MetaAd[]

  @@index([organizationId])
  @@index([adAccountId])
  @@map("meta_ad_campaigns")
}

model MetaAdSet {
  id               String             @id @default(cuid())
  organizationId   String             @map("organization_id")
  campaignId       String             @map("campaign_id")
  metaAdsetId      String?            @unique @map("meta_adset_id")
  name             String
  status           MetaAdEntityStatus @default(PAUSED)
  effectiveStatus  String?            @map("effective_status")
  optimizationGoal String?            @map("optimization_goal")
  billingEvent     String?            @map("billing_event")
  bidAmount        Decimal?           @map("bid_amount") @db.Decimal(14, 4)
  dailyBudget      Decimal?           @map("daily_budget") @db.Decimal(14, 2)
  lifetimeBudget   Decimal?           @map("lifetime_budget") @db.Decimal(14, 2)
  targeting        Json?
  startTime        DateTime?          @map("start_time")
  endTime          DateTime?          @map("end_time")
  lastSyncedAt     DateTime?          @map("last_synced_at")
  raw              Json?
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")

  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  campaign     MetaAdCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  ads          MetaAd[]

  @@index([organizationId])
  @@index([campaignId])
  @@map("meta_adsets")
}

model MetaAd {
  id              String             @id @default(cuid())
  organizationId  String             @map("organization_id")
  campaignId      String             @map("campaign_id")
  adsetId         String             @map("adset_id")
  metaAdId        String?            @unique @map("meta_ad_id")
  name            String
  status          MetaAdEntityStatus @default(PAUSED)
  effectiveStatus String?            @map("effective_status")
  creativeId      String?            @map("creative_id")
  creative        Json?
  previewUrl      String?            @map("preview_url")
  lastSyncedAt    DateTime?          @map("last_synced_at")
  raw             Json?
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")

  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  campaign     MetaAdCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  adset        MetaAdSet      @relation(fields: [adsetId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([campaignId])
  @@index([adsetId])
  @@map("meta_ads")
}

// ────────────────────────────────────────────────────────────────────────────
// Meta Ads MCP (Astro IA)
// ────────────────────────────────────────────────────────────────────────────

/// Autorização explícita pra um usuário usar o Astro Meta Ads via MCP.
/// Owner e Moderador têm autorização IMPLÍCITA pelo role — não precisam de
/// registro aqui. Admin e Member precisam de grant explícito (autorizado
/// por owner ou moderador). `revokedAt` faz soft-delete preservando histórico.
model MetaMcpAuthorization {
  id             String    @id @default(cuid())
  organizationId String    @map("organization_id")
  userId         String    @map("user_id")
  authorizedById String    @map("authorized_by_id")
  authorizedAt   DateTime  @default(now()) @map("authorized_at")
  revokedAt      DateTime? @map("revoked_at")
  notes          String?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation("McpAuthorizedUser", fields: [userId], references: [id], onDelete: Cascade)
  authorizedBy User         @relation("McpAuthorizedBy", fields: [authorizedById], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([organizationId])
  @@map("meta_mcp_authorizations")
}

/// Operação Meta Ads de escrita PROPOSTA pelo Astro mas ainda não executada.
/// Astro chama `meta_ads_propose_*` que persiste aqui com TTL curto (5min).
/// UI mostra card de confirmação. Click em Confirmar → `executeMcpAction`
/// lê pendingAction, valida ownership/TTL, executa via MCP, marca executed.
model MetaAdsPendingAction {
  id             String    @id @default(cuid())
  organizationId String    @map("organization_id")
  userId         String    @map("user_id")
  toolName       String    @map("tool_name") // ex: "meta_ads_pause_campaign"
  payload        Json // params validados pela tool
  summary        String // texto pro UI
  status         String    @default("pending") // pending | executed | cancelled | expired
  expiresAt      DateTime  @map("expires_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  executedAt     DateTime? @map("executed_at")
  errorMessage   String?   @map("error_message")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([organizationId, status, expiresAt])
  @@index([userId])
  @@map("meta_ads_pending_actions")
}

// ─────────────────────────────────────────────────────────────────────────────
// ASTRO — Agentes IA da NASA
//
// Arquitetura:
//  • AiAgentConfig: configuração por agente, escopo Organization (toggle, modo
//    AUTO/TRIGGER/MANUAL, knowledge bases vinculadas).
//  • AiSession: histórico de conversa. messages é UIMessage[] (AI SDK) em Json.
//    /home lista sessões "livres" (context IS NULL). Embeds salvam com
//    context = { scope: "lead", leadId } etc. e ficam fora desse feed.
//  • AiKnowledge / AiKnowledgeChunk: base de conhecimento (RAG via pgvector).
//    Coluna `embedding vector(1536)` é adicionada em AiKnowledgeChunk via
//    migration SQL manual (Prisma omite). Retrieval usa $queryRaw + Prisma.sql.
// ─────────────────────────────────────────────────────────────────────────────

enum AiAgentMode {
  AUTO
  TRIGGER
  MANUAL
}

enum AiKnowledgeStatus {
  PENDING
  PROCESSING
  READY
  ERROR
}

model AiAgentConfig {
  id             String      @id @default(cuid())
  organizationId String      @map("organization_id")
  agentKey       String      @map("agent_key") // "astro" | "closer" | "task-agent" | ...
  enabled        Boolean     @default(true)
  mode           AiAgentMode @default(MANUAL)
  knowledgeIds   String[]    @default([]) @map("knowledge_ids")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, agentKey])
  @@index([organizationId])
  @@map("ai_agent_config")
}

model AiSession {
  id             String   @id @default(cuid())
  organizationId String   @map("organization_id")
  userId         String   @map("user_id")
  title          String?
  messages       Json     @default("[]") // UIMessage[] do AI SDK
  context        Json? // null = sessão livre (/home); { scope, ...ids } = embed contextual
  lastAgentKey   String?  @map("last_agent_key")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([organizationId, userId, updatedAt(sort: Desc)])
  @@map("ai_session")
}

model AiKnowledge {
  id             String            @id @default(cuid())
  organizationId String            @map("organization_id")
  name           String
  type           String // "pdf" | "xlsx" | "docx" | "txt" | "csv"
  fileUrl        String?           @map("file_url") // R2/S3
  status         AiKnowledgeStatus @default(PENDING)
  chunksCount    Int               @default(0) @map("chunks_count")
  errorMessage   String?           @map("error_message")
  createdBy      String            @map("created_by")
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")

  organization Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  creator      User               @relation("AiKnowledgeCreatedBy", fields: [createdBy], references: [id], onDelete: Restrict)
  chunks       AiKnowledgeChunk[]

  @@index([organizationId])
  @@index([status])
  @@map("ai_knowledge")
}

model AiKnowledgeChunk {
  id             String   @id @default(cuid())
  knowledgeId    String   @map("knowledge_id")
  organizationId String   @map("organization_id") // dup p/ filtros rápidos no $queryRaw
  content        String   @db.Text
  // embedding vector(1536) — adicionada via migration SQL manual
  createdAt      DateTime @default(now()) @map("created_at")

  knowledge AiKnowledge @relation(fields: [knowledgeId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([knowledgeId])
  @@map("ai_knowledge_chunk")
}
